            if (!isActionAllow) {
                return false;
            }
            if (type == "Url") {
                var url = processUrl(pageurl.replaceAll('&amp;', '&').replaceAll('&#39;', "'"), d);
                if (url.startsWith("javascript")) {
                    window.location.href = url;
                }
                else if (pagetype === "Same Page") {
                    window.location.href = "../../../../../../../" +url;
                }
                else if (pagetype === "New Tab") {
                    window.open("../../../../../../../" +url);
                }
                else {
                    $('#myframe').attr('src', "../../../../../../../" +url);
                    $('#mdl-iframe .modal-title').html(title)
                    $('#mdl-iframe .modal-footer').remove();
                    $('#mdl-iframe').modal("show");
                }
            }
            if (type == "Api") {
                var url = processUrl(pageurl.replaceAll('&amp;', '&').replaceAll('&#39;', "'"), d);
                gowithData(url, "post", {}, function (resp) {
                    if (resp.error) {
                        alertError(resp.message);
                    }
                    else {
                        alertSuccesNotification(resp.message);
                        setTimeout(function () {
                            window.location.reload();
                        },1000)
