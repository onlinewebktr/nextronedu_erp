        function processGroupingText(d) {
            var format = '@mpc.OtherData["data_grouping"]';
            const pattern = /{([^}]*)}/g;
            const matches = format.match(pattern);
            if (matches) {
                matches.forEach(match => {

                    const vrbl = match.match(/{([^}]*)}/)[1];
                    format = format.replace(match, d[g_cols[vrbl]]);
                });
            }
            return format;
