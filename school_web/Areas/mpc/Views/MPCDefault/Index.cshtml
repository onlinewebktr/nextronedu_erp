    var first_element = "";
    var area = ViewBag.sector as String;
    var sector = ViewBag.sector;
    var allowExcelUplad = false;
    var filterId = 1;
    var showBreadCrumb = true;
    if (mpc.OtherData != null)
    {
        if (!formOnly && mpc.OtherData.ContainsKey("Page_Layout_Path"))
        {
            if (mpc.OtherData["Page_Layout_Path"] != "")
            {
                Layout = mpc.OtherData["Page_Layout_Path"];
            }
            else
            {
                Layout = MPC.getLauout(sector);
            }

        }
        else
        {
            Layout = MPC.getLauout(sector);
        }

        if (mpc.OtherData.ContainsKey("allowCSVUpload"))
        {
            if (mpc.OtherData["allowCSVUpload"] == "Yes")
            {
                allowExcelUplad = true;
            }
        }
        if (mpc.OtherData.ContainsKey("showBreadCrumb"))
        {
            if (mpc.OtherData["showBreadCrumb"] == "Hide")
            {
                showBreadCrumb = false;
            }
        }
        if (ViewBag.MainLayout != null)
        {
            Layout = ViewBag.MainLayout;
        }

    }
    if (mpc.formType == "LeftRight")
    {
        if (!mpc.action.isAddNewAllow)
        {
            formclass = "col-lg-12";
            dataclass = "col-lg-12";
            mpc.formType = "PopUp";
            modaltype = "modal-md";
        }
        else
        {
            formclass = "col-lg-4";
            dataclass = "col-lg-8";
        }
    }

    //if (!mpc.OtherData.ContainsKey("data_grouping"))
    //{
    //    mpc.OtherData["data_grouping"] = "";
    //}
    var requiredFields = "";
    var col_count = 1;
    foreach (var p in mpc.pcd)
    {
        if (p.isField)
        {
            if (p.isRequired)
            {
                requiredFields += p.columnName + ",";
            }
            if (first_element == "")
            {
                first_element = p.columnName;
            }
        }
    }
    requiredFields = requiredFields.TrimEnd(',');

    var display_website = "";
    var display_email = "";
    var display_contact_no = "";
    var address2 = "";
    if (ViewBag.website == "")
    {
        display_website = "; display:none;";
    }
    if (ViewBag.Email == "")
    {
        display_email = "; display:none;";
    }
    if (ViewBag.address2 == null || ViewBag.address2 == "")
    {
        address2 = "; display:none;";
    }
    if (ViewBag.contact_no == "")
    {
        display_contact_no = "; display:none;";
    }
}

<script>

    const sector = '@ViewBag.sector'
    var requiredFields = '@requiredFields'.split(",");;
    var reportSubTitle = "";

    function DisplayDate(dateString) {
        let date = new Date(dateString);

        if (isNaN(date)) {
            return "Invalid Date"; // Handle invalid date input
        }

        const options = { day: '2-digit', month: 'short', year: 'numeric' };
        return date.toLocaleDateString('en-GB', options).replace(',', '');
    }
</script>

