        function calculateFooter() {
               var  fvs = {};
                @foreach (var g in mpc.gcd)
                {
                    if (g.isShowOnGrid)
                    {
                        if (g.showFooter == "Total(Text)")
                        {
                        @:fvs.@g.columnName = "Total";
                    }
                        else if (g.showFooter == "Sum")
                        {
                         @:fvs.@g.columnName = 0;
                    }
                        else if (g.showFooter == "Count")
                        {
                           @:fvs.@g.columnName = 0;
                    }
                    }
                }

            if (Object.keys(fvs).length) {

                $('#mytable tbody tr').each(function () {
                @{
                    int g_indx = 0;
                    if (allowaction)
                    {
                        g_indx = 1;
                    }
                    foreach (var g in mpc.gcd)
                    {
                        if (g.isShowOnGrid)
                        {
                            if (g.showFooter == "Sum")
                            {
                            @:fvs.@g.columnName = fvs.@g.columnName + toFloat($(this).find('td:eq(@g_indx)').text());
                            }
                            else if (g.showFooter == "Count")
                            {
                            @:fvs.@g.columnName = fvs.@g.columnName + 1;
                            }
                            g_indx += 1;
                        }
                    }
                }
                });
                var tfoot = $('#mytable tfoot');
                tfoot.empty();
                var fr = $('<tr>');
                if (showAction) {
                    fr.append($('<th>'));
                }
                fr.append(
                @foreach (var g in mpc.gcd)
                {
                    if (g.isShowOnGrid)
                    {

                       @: $('<th>').text(fvs.@g.columnName),
                    }
                }
                );
                tfoot.append(fr);
            }
        }
