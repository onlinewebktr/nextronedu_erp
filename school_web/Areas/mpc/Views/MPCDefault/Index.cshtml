                    //    $('#btn-save').focus();
                    //}
                    //else {
                    //    moveFocus(elmnt, '#myForm');
                    //}
                    moveFocus(elmnt, '#main-form');

                }, 50);
            });
        }


        window.onclick = function(event) {
            if (!$(event.target).closest('.dropdown-button').length) {
                $('.dropdown-menu').hide();
