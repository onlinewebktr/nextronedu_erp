        function apply_enter_event(formId) {
            $(`${formId} input:not([type="button"]), ${formId} select, ${formId} textarea`).on('keydown', function (e) {
                if (e.key === 'Enter') {
                    e.preventDefault(); // Prevent form submission on Enter
                    moveFocus(this, formId)
                }
            });
        }
        function moveFocus(elmt, formId) {
            var fields = $(formId).find('input, select, textarea, button');
            var index = fields.index(elmt);
            if (index > -1) {
                // Find the next visible element
                var nextIndex = index + 1;

                //if (formId == "#tbl_grd_view") {
                //    if (nextIndex == fields.length) {
                //        $('#btn-save').focus();
                //        return;
                //    }
                //}

                while (nextIndex < fields.length) {
                    // Check if the next field is visible and enabled
                    if ($(fields[nextIndex]).is(':visible') && $(fields[nextIndex]).is(':enabled')) {
                        fields.eq(nextIndex).focus();
                        break; // Exit the loop once focused
                    }
                    nextIndex++;
                }
            }
        }

        function select2Suggestion(elmnt) {
            // Initialize Select2
            $(elmnt).select2({
                openOnEnter: false
            });
            $(elmnt).on('focus', function () {
