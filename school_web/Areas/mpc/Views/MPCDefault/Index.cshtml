        function processGroupingText2(d) {
            var format = '@mpc.OtherData["data_grouping"]';
            const pattern = /{([^}]*)}/g;
            const matches = format.match(pattern);
            if (matches) {
                matches.forEach(match => {

                    const vrbl = match.match(/{([^}]*)}/)[1];
                    format = format.replace(match, d[vrbl]);
                });
            }
            return format;
        }
        var groupCols = [];
        var groupColsIndx = [];
        function getGroupCols(d) {
            var format = '@mpc.OtherData["data_grouping"]';
            const pattern = /{([^}]*)}/g;
            const matches = format.match(pattern);
            if (matches) {
                matches.forEach(match => {
                    const vrbl = match.match(/{([^}]*)}/)[1];
                    groupCols.push(vrbl);
                });
            }
