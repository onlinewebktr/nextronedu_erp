        @Html.pageEvents(mpc.events)
        <script>
        $(function () {

            @{
                if (mpc.OtherData.ContainsKey("addNewPopup"))
                {
                    var adpup = mpc.OtherData["addNewPopup"];
                    foreach (var p in adpup)
                    {
                        if (p["url"] != "")
                        {
                             @:applyAddMore('@p["displayText"]','@p["fieldName"]','@p["url"]');
                        }
                    }
                }
            }
            $('#mdl-add-more').on('hidden.bs.modal', function () {
                reBindddl(select_add_more_field)
            });

            $('#mdl-add-more .modal-footer').remove();
            $('#mdl-add-more .modal-body').css('padding','0');

            $('#moreframe').on('load',function () {
                $(this).height($(this).contents().find('body').height());
            });

        })
        var select_add_more_field = "";
        function applyAddMore(displayText,fieldName,url)
        {

            var btn = $(`<span class="btn-more"><i class="bx bx-plus"></i></span>`);

            $(`label[for="${fieldName}"]`).first().append(btn);
            btn.on('click', function () {
                select_add_more_field = fieldName;
                $('#mdl-add-more .modal-title').html(displayText);
                $('#mdl-add-more').modal("show");
                $('#moreframe').attr('src', url);

            });
    }

    function reBindddl(amf_field_name )
    {
        var pageId = $('#frm-page-Id').val();
        var data = { frm_pageId: pageId, frm_targetId: amf_field_name };
        var formData = $('#main-form').serializeArray();
        $.map(formData, function (input) {
            data[input.name] = input.value;
        });
        data['amf_field_name'] = amf_field_name;
        gowithData('../../../../@sector/mpc-data/rebind-ddl', 'Post', JSON.stringify({ data: data }), function (resp) {
            if (!resp.error) {
                $('#' + amf_field_name).html(resp.data)
                if (isEdit) {
                    $('#address1').val($('#firm_name').attr('data-address1'));
                    $('#address1').change();
                }
            }
        })
    }


        </script>

        @if (formOnly)
