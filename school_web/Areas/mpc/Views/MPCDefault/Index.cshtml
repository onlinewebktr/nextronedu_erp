<script>
        function mpc_autocomplete(acb, field_id,filterId,area)
        {

            $(acb).autocomplete({
                source: function (request, response) {
                    var data = { search: request.term, filterId: filterId, pageId: '@mpc.pageId' }
                    gowithData(`../../../${area}/mpc-data/acb`, "POST", JSON.stringify({ data: data }), function (resp) {
                        if (!resp.error) {
                            //response(resp.data);
                            response($.map(resp.data, function (d) {
                                const keys = Object.keys(d);
                                if (keys.length == 1) {
                                    return {
                                        label: d[keys[0]],
                                        value: d[keys[0]],
                                    };
                                }
                                else {
                                    return {
                                        label: d[keys[0]],
                                        value: d[keys[1]],
                                    };
                                }

                            }))
                        }
                    })
                },
                select: function (event, ui) {
                    this.value = ui.item.label; // Set the input value to the selected item's value
                    $("#"+field_id).val(ui.item.value);
                    return false; // Prevent the default behavior
                },
                minLength: 2
            }).data("ui-autocomplete")._renderItem = function (ul, item) {
                return $("<li>")
                    .append("<div>" + item.label + "</div>")
                    .appendTo(ul);
            };
        }
        function getCurrentDate() {
            const today = new Date();
            const year = today.getFullYear();
            const month = String(today.getMonth() + 1).padStart(2, '0'); // Months are zero-based
            const day = String(today.getDate()).padStart(2, '0');

            return `${year}-${month}-${day}`;
        }

</script>
