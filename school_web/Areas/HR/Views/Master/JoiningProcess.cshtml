                gowithData("../../hr/data/ddl", "POST", JSON.stringify({ data: { type: 'GradeDesignation' } }), function (resp) {
                    if (!resp.error) {
                        var ddl = $('#Grade');
                        $("#Grade option:not(:first)").remove();
                        $.each(resp.grade, function (i, item) {
                            ddl.append($("<option>").text(item.grade_name).val(item.grade_id));
                        });
                        ddl.val('@emp.Grade')
                        //ddl = $('#Department');
                        //$("#Department option:not(:first)").remove();
                        //$.each(resp.department, function (i, item) {
                        //    ddl.append($("<option>").text(item.name).val(item.department_id));
                        //});
                        //ddl = $('#Designation');
                        //$("#Designation option:not(:first)").remove();
                        //$.each(resp.designation, function (i, item) {
                        //    ddl.append($("<option>").text(item.name).val(item.Designation_id));
                        //});
                    }
                })
                gowithData("../../hr/data/salary_structure_apply", "POST", JSON.stringify({ data: { App_id: '@emp.Apply_id' } }), function (resp) {
                    if (!resp.error) {

                        deductions = resp.deduction_head;
                        incomes = resp.income_heads;
                        bind_income_table()
                        bind_deduction_table()
                        var basic = 0
                        var gross = 0;
                        var total_deduct = 0;
                        var emp_contri = 0;
                        $.each(incomes, function (i, item) {
                            if (item.IsBasic == 'Yes') {
                                basic += parseFloat(item.inc)
                            }
                            gross += parseFloat(item.inc)
                        });
                        $.each(deductions, function (i, item) {
                            total_deduct += item.deduct
                            emp_contri += item.deduct_emp
                        });
                        $('#Gross').text(gross);
                        $('#Deduction').text(total_deduct);
                        $('#lblGross').text(gross);
                        $('#lblDeduction').text(total_deduct);
                        $('#lblNet_Salary').text(gross - total_deduct);
                        $('#lblEmployeer_Contribution').text(emp_contri);
                        $('#lblCTC_month').text(gross + emp_contri);
                        $('#lblCTC_year').text((gross + emp_contri) * 12);
                    }
                })
            })
            function bindEmployeeList() {
                var data = { type: 'name_initital' };
                gowithData("../../hr/data/ddl", "POST", JSON.stringify({ data: data }), function (resp) {
                    if (!resp.error) {
                        var ddl = $('#Salutation');
                        $("#Salutation option:not(:first)").remove();
                        $.each(resp.data, function (i, item) {
                            ddl.append($("<option>").text(item.Initial_name).val(item.Initial_id));
                        });
                        ddl.val('@emp.Salutation')
                    }
                })
            }
            function gotoPage(eid) {
                $("#current_tab").val(eid);
                $("#stepper-div").children().removeClass("active");
               $("#stepper-div").children().removeClass("completed");
                $.each($("#stepper-div").children(), function (index, el) {
                    var di = '#' + $(el).attr('data-id')
                    if (index < eid) {
                        $(el).addClass('completed')
                        $(di).hide();
                    }
                    else if (index == eid) {
                        $(el).addClass('active')
                        $(di).show();
                    }
                    else {
                        $(di).hide();
                        $(el).removeClass('completed')
                        $(el).removeClass('active')
                    }

                })
                $('#btn-back').hide();
                $('#btn-next').hide();
                $('#btn-submit').hide();
                if (eid > 0) {
                    $('#btn-back').show();
                }
                if (eid < 7) {
                    $('#btn-next').show();
                }
                if (eid == 7) {
                    $('#btn-submit').show();
                }
            }
            $('#btn-back').click(function () {
                var currentValue = parseInt($("#current_tab").val());
                if (currentValue > 0) {
                    currentValue = currentValue - 1;
                    gotoPage(currentValue);
                }

            })
            $('#btn-next').click(function () {

                var currentValue = parseInt($("#current_tab").val());
