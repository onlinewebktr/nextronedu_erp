                    if ($("#Religion").val() == "" || $("#Religion").val() == "Select" || $("#Religion").val() == null) {
                        $("#Religion").val("HINDU")
                    }
                    if ($("#Nationality").val() == "" || $("#Nationality").val() == "Select" || $("#Nationality").val() == null) {
