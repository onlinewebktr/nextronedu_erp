                            @Html.LabelEditor("mother_name", "text", "Mother Name", emp.mother_name, divCssClass: "col-md-3")
                            @Html.LabelEditor("mother_occupation", "text", "Mother Occupation", emp.mother_occupation, divCssClass: "col-md-3")


                            @Html.LabelEditor("Spouse_name", "text", "Spouse Name", emp.Spouse_name, divCssClass: "col-md-3")
                            @Html.LabelEditor("spouse_qualification", "text", "Spouse's Qualification", emp.spouse_qualification, divCssClass: "col-md-3")
                            @Html.LabelEditor("spouse_profession", "text", "Spouse's Profession", emp.spouse_profession, divCssClass: "col-md-3")
                            @Html.LabelEditor("Spouses_job_is_transferable", "ddl", "Spouse's job is transferable", emp.Spouses_job_is_transferable, divCssClass: "col-md-3", ddl_comma_seperated: "YES,NO,N/A")
                            @Html.LabelEditor("spouse_organization", "text", "Spouse's Organization", emp.spouse_organization, divCssClass: "col-md-6")
                            @Html.LabelEditor("spouse_designation", "text", "Spouse's Designation", emp.spouse_designation, divCssClass: "col-md-3")



                        </div>
                        <h2 class="form-ttleS">Children Information</h2>
                        <div class="row">
                            @Html.LabelEditor("chiled_name1", "text", "Name", emp.chiled_name1, divCssClass: "col-md-4")
                            @Html.LabelEditor("chiled_gender1", "ddl", "Gender", emp.chiled_gender1, divCssClass: "col-md-4", ddl_comma_seperated: "MALE,FEMALE, THIRD GENDER")
                            @Html.LabelEditor("chiled_age1", "number", "Age", emp.chiled_age1, divCssClass: "col-md-4")

                            @Html.LabelEditor("chiled_name2", "text", "Name", emp.chiled_name2, divCssClass: "col-md-4")
                            @Html.LabelEditor("chiled_gender2", "ddl", "Gender", emp.chiled_gender2, divCssClass: "col-md-4", ddl_comma_seperated: "MALE,FEMALE, THIRD GENDER")
                            @Html.LabelEditor("chiled_age2", "number", "Age", emp.chiled_age3, divCssClass: "col-md-4")

                            @Html.LabelEditor("chiled_name3", "text", "Name", emp.chiled_name3, divCssClass: "col-md-4")
                            @Html.LabelEditor("chiled_gender3", "ddl", "Gender", emp.chiled_gender3, divCssClass: "col-md-4", ddl_comma_seperated: "MALE,FEMALE, THIRD GENDER")
                            @Html.LabelEditor("chiled_age3", "number", "Age", emp.chiled_age3, divCssClass: "col-md-4")

                        </div>




                    </div>

                    <div class="p-4 border rounded" style="padding: 0px 0px 20px 0px !important; float: left; width: 100%;" id="Page_Academic_Maped" visible="false">
                        <div class="p-4 border rounded" style="padding: 0px 0px 20px 0px !important; float: left; width: 100%;" id="Page_Academic_Maped" visible="false">

                            <h2 class="form-ttleS">Academic Qualification</h2>
                            <div class="row">
                                <div class="col-12">

                                    <table class="table-bordered" id="#lngs" style="width: 100%;">
                                        <thead>
                                            <tr>
                                                <th style="width: 55px;">SL No</th>
                                                <th style="width: 130px;">Qualification</th>
                                                <th>Main Subjects</th>
                                                <th>School/College</th>
                                                <th>Board/University</th>
                                                <th>Year of Passing</th>
                                                <th>Full Marks</th>
                                                <th>Marks Obtained</th>
                                                <th>Percentage of Marks</th>
                                                <th>Division</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @{
                                                var dict = new Dictionary<string, string>();
                                                dict["metric"] = "High School/10th";
                                                dict["inter"] = "Inter/+2";
                                                dict["grad"] = "Graduation";
                                                dict["pg"] = "Post Graduation";
                                                dict["mp"] = "PHD";
                                                if (My.isHospital)
                                                {
                                                    dict["md"] = "MD";
                                                    dict["mbbs"] = "MBBS";
                                                }
                                                else if (My.isSchool)
                                                {
                                                    dict["b_ed"] = "B.Ed";
                                                    dict["m_ed"] = "M.Ed";
                                                }
                                                else
                                                {

                                                }
                                                dict["oth"] = "Any Other";
                                                var cnt = 0;
                                                foreach (var key in dict.Keys)
                                                {
                                                    cnt++;
                                                    <tr>
                                                        <th style="text-align:center">@cnt</th>
                                                        <th>@dict[key]</th>
                                                        <td> @Html.TextBox(@key + "_sub", "", new { @class = "form-control" }) </td>
                                                        <td> @Html.TextBox(@key + "_school", "", new { @class = "form-control" }) </td>
                                                        <td> @Html.TextBox(@key + "_board", "", new { @class = "form-control" }) </td>
                                                        <td> @Html.TextBox(@key + "_year", "", new { @class = "form-control" }) </td>
                                                        <td> @Html.TextBox(@key + "_f_marks", "", new { @class = "form-control f_marks", mkey = key }) </td>
                                                        <td> @Html.TextBox(@key + "_marks_obtain", "", new { @class = "form-control f_marks", mkey = key }) </td>
                                                        <td> @Html.TextBox(@key + "_marks", "", new { @class = "form-control", mkey = key }) </td>
                                                        <td> @Html.DropDownList(@key + "_division", "DISTINCTION,FIRST,SECOND,THIRD,NA", "Select", new { @class = "form-select" }) </td>
                                                    </tr>
                                                }
                                            }

                                        </tbody>

                                    </table>
                                </div>

                            </div>
                            <script>
                                $(function () {
                                    mevent();
                                })
                                function mevent() {
                                    $(".f_marks").on("input", function () {
                                        var key = $(this).attr("mkey");

                                        var fm = parseFloat($(`#${key}_f_marks`).val());
                                        console.log(fm);
                                        // Checking if 'fm' is not a number or is NaN, and setting it to 1 if true
                                        if (isNaN(fm) || !isFinite(fm)) {
                                            fm = 1;
                                        }

                                        // Extracting and converting the value of an input field with the ID `${key}_marks_obtain` to a floating-point number
                                        var mo = parseFloat($(`#${key}_marks_obtain`).val());

                                        // Checking if 'mo' is not a number or is NaN, and setting it to 0 if true
                                        if (isNaN(mo) || !isFinite(mo)) {
                                            mo = 0;
                                        }

                                        // Calculating the percentage only if 'fm' is not zero to avoid division by zero
                                        var p = fm !== 0 ? (mo * 100) / fm : 0;

                                        // Updating the value of an input field with the ID `${key}_marks`
                                        $(`#${key}_marks`).val(p.toFixed(2));
                                    })
                                }

                            </script>



                            <h2 class="form-ttleS">Experience Details</h2>
                            <div class="row">
                                <div class="col-12">

                                    <table class="table-bordered" id="tbl_exp" style="width: 100%;">
                                        <thead>
                                            <tr>
                                                <th style="width: 55px;">SL No</th>
                                                <th style="min-width: 300px;">Name of the Organization</th>
                                                <th>Designation</th>
                                                <th>Employment Duration</th>
                                                <th>Drawn Salary (Gross)</th>
                                                <th>Reason For Leaving</th>
                                            </tr>
                                        </thead>
