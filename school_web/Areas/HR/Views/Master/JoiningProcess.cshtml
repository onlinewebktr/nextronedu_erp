                    <div class="p-4 border rounded" style="padding: 0px 0px 20px 0px !important; float: left; width: 100%;" id="page_communication_address_info" visible="false">
                        <h2 class="form-ttleS">Communication Address</h2>

                        <div class="g-3 needs-validation" style="padding: 0px 10px 10px 10px;">


                            <div class="row">
                                @Html.LabelEditor("Address_CA", "text", "Address", emp.Address_CA, true, divCssClass: "col-md-6")
                                @Html.LabelEditor("City_CA", "text", "City", emp.City_CA, true, divCssClass: "col-md-3")
                                @Html.LabelEditor("State_CA", "text", "State", emp.State_CA, true, divCssClass: "col-md-3")
                                @Html.LabelEditor("Pincode_CA", "text", "Pin Code", emp.Pincode_CA, true, divCssClass: "col-md-3")
                                @Html.LabelEditor("mobile_no_CA", "text", "Mobile No", emp.mobile_no_CA, divCssClass: "col-md-3", isRequired: true)
                                @Html.LabelEditor("Residence_telephone_no_CA", "text", "Residence Telephone No", emp.Residence_telephone_no_CA, divCssClass: "col-md-3")


                            </div>


                            @*<h2 class="form-ttleS">
            Permanent Address (Check this box if Communication Address & Permanent Address are the same.)
            <asp:CheckBox ID="chk_same_check_box" OnCheckedChanged="chk_same_check_box_CheckedChanged" AutoPostBack="true" />
        </h2>*@
                            <div class="form-group form-check p-3 mx-3">
                                <input style="font-size:18px; color:#000" type="checkbox" class="form-check-input" id="chk_same_check_box" onchange="handleCheckboxChange()" OnCheckedChanged="chk_same_check_box_CheckedChanged" AutoPostBack="true">
                                <label class="form-check-label" for="chk_same_check_box">Permanent Address (Check this box if Communication Address & Permanent Address are the same.)</label>
                            </div>

                            <script>
                                function handleCheckboxChange() {
                                    var checkbox = document.getElementById("chk_same_check_box");
                                    var addressCA = document.getElementById("Address_CA");
                                    var pAddressCA = document.getElementById("address_pa");
                                    var City_CA = document.getElementById("City_CA");
                                    var State_CA = document.getElementById("State_CA");
                                    var Pincode_CA = document.getElementById("Pincode_CA");
                                    var city_pa = document.getElementById("city_pa");
                                    var state_pa = document.getElementById("state_pa");
                                    var pin_pa = document.getElementById("pin_pa");

                                    if (checkbox.checked) {
                                        // If checkbox is checked, copy values from Address_CA to P_Address_CA
                                        pAddressCA.value = addressCA.value;
                                        city_pa.value = City_CA.value;
                                        state_pa.value = State_CA.value;
                                        pin_pa.value = Pincode_CA.value;
                                    } else {
                                        // If checkbox is unchecked, you may want to clear P_Address_CA or handle it differently
                                        pAddressCA.value = "";
                                        city_pa.value = "";
                                        state_pa.value = "";
                                        pin_pa.value = "";
                                    }
                                }
                            </script>

                            <div class="row">

                                @Html.LabelEditor("address_pa", "text", "Address", emp.address_pa, true, divCssClass: "col-md-6")
                                @Html.LabelEditor("city_pa", "text", "City", emp.city_pa, true, divCssClass: "col-md-3")
                                @Html.LabelEditor("state_pa", "text", "State", emp.state_pa, true, divCssClass: "col-md-3")
                                @Html.LabelEditor("pin_pa", "text", "Pin Code", emp.pin_pa, true, divCssClass: "col-md-3")



                            </div>

                        </div>


                    </div>

