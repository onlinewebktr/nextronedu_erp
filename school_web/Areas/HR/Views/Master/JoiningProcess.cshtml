                    }
                    if ($("#Marital_Status").val() == "" || $("#Marital_Status").val() == "Select" || $("#Marital_Status").val() == null) {
                        $("#Marital_Status").val("UNMARRIED");
                    }
                    //if ($("#passport_photo").val() == "") {
                    //    alertError("A Passport Size Photo is required");
                    //    return false;
                    //}
                    //if ($("#Signature").val() == "") {
                    //    alertError("Signature is required");
                    //    return false;
                    //}
                }
                if (currentValue == 1) {
                    if ($("#Address_CA").val() == "") {
                        alertError("Address is required");
                        return false;
                    }
                    if ($("#City_CA").val() == "") {
                        alertError("City is required");
                        return false;
                    }
                    if ($("#State_CA").val() == "") {
                        alertError("State is required");
                        return false;
                    }
                    if ($("#Pincode_CA").val() == "") {
                        alertError("Pincode is required");
                        return false;
                    }
                    if ($("#address_pa").val() == "") {
                        alertError("Permanent Address is required");
                        return false;
                    }
                    if ($("#mobile_no_CA").val() == "") {
                        alertError("Mobile No is required");
                        return false;
                    }

                }
                if (currentValue == 2) {

                    if ($("#fathername").val() == "") {
                        alertError("Father Name is required");
                        return false;
                    }

                }
                if (currentValue == 3) {


                    if ($("#Under_Service_Bond").val() == "" || $("#Under_Service_Bond").val() == "Select" || $("#Under_Service_Bond").val() == null) {
                        $("#Under_Service_Bond").val('No');
                    }

                }
                if (currentValue == 4) {
                    if ($("#Proficiency_In_Computer").val() == "" || $("#Proficiency_In_Computer").val() == "Select" || $("#Proficiency_In_Computer").val() == null) {

                        $("#Proficiency_In_Computer").val('No');
                    }
