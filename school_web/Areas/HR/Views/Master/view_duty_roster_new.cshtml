            position: absolute;
            left: 0;
            top: 0;
        }

        .page-wrapper {
            margin-top: 0px;
            margin-left: 0px;
        }

        .noprint {
            max-height: 0;
            visibility: hidden;
            display: none;
        }
    }
</style>
