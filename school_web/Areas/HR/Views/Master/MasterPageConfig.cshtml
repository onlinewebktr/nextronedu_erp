        ddl_event.append(op_options);
        var div = $('<div>').append(req).append(ddl);
        var event = $('<div>').append('<label for="onchange_' + p.columnName + '">Data On change</label><input  ' + (p.onChanged ? 'checked' : '') + ' data-id="ddl_event_' + p.columnName + '" onchange="event_changed(this)"  class="event-chk ms-2 me-2 " id="onchange_' + p.columnName + '"    type="checkbox"  >', ddl_event);
        ddl.val(p.fieldType)

        //[{"columnName":"PageType","displayText":"Page Type","fieldType":"TextBox","requiredData":"","isRequired":false}
        //<i class='bx bxs-x-square' style='color:#d01644'  ></i>
           // < i class='bx bxs-up-arrow-square' style = 'color:#3e64e6' ></i >
        var row = $('<tr>').append(
            
            $('<td>').prop('style', 'width:22%;').append('<span style="display: inline-flex; margin-top: -5px;"> <i onclick="goup(this)"  data-id="pcd" data-index="' + index + '" class="bx bxs-up-arrow-square m-0" style="font-size:20px; color:#3e64e6;"></i> <i  onclick="removeme(this)"  data-id="pcd" data-index="' + index + '" class="bx bxs-x-square m-0" style="font-size:20px; color:#d01644"></i> <span style="margin-top: 5px;">' + p.columnName+'</span></span>').append('<input type="text" class="form-control pcd" style="margin-top: -4px;" value="' + p.displayText + '" id="txt_disp_' + p.columnName + '" />'),
            $('<td>').prop('style', 'width:18%;').append(div),
