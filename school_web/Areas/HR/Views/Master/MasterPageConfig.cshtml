            $('#chk_delete').prop('checked', true);
            $('#frm-is-customised-grid').prop('checked', false);
            load_events();
            $('#Page_Layout_Path').val('');
            $('#Custom_View').val('');
        }
        else {

            ispageChange = true;
            var data = { data: { pageId: pageId } }
            gowithData("../../hr/data/page", 'POST', JSON.stringify(data), function (resp) {

                $.each(resp.data, function (index, d) {
                    $('#ddl_table').val(d.tableName);
                    if (!$('#ddl_table').val()) {
                        console.log(`tableName : ${d.tableName} is not match`);
                        $('#ddl_table').val(d.tableName.toUpperCase());
                    }
                    $('#ddl_table').change();
                    $('#pageTitle').val(d.pageTitle);
                    $('#pageUrl').val(d.pageUrl);
                    $('#pageType').val(d.pageType);
                    $('#ddl_formtype').val(d.formType);
                    $('#methodId').val(d.methodId);
                    $('#DataQuery').val(d.dataQuery);
                    $('#simpleQuery').val(d.sampleQuery);

                    $('#frm-is-customised-grid').prop('checked', d.isCustomisedGrid);
                    pcd = JSON.parse(d.pcd);
                    gcd = JSON.parse(d.gcd);

                    //add missing new Cols
                    $.each(resp.cols, function (ind, col) {
                        if (!pcd.some(item => item.columnName === col)) {
                            var p = {};
                            p.columnName = col;
                            p.isRequired = false;
                            p.onChanged = false;
                            p.displayText = displayText(col);
                            p.requiredData = '';
                            p.fieldType = 'Not a Field';
                            p.defaultValue = '';
                            p.cssclass = '';
                            pcd.push(p);
                        }
                        if (!d.isCustomisedGrid) {
                            if (!gcd.some(item => item.columnName === col)) {
                                var p = {};
                                p.columnName = col;
                                p.isShowOnGrid = false;
                                p.displayText = displayText(col);
                                p.requiredData = '';
                                p.dataType = 'Text';
                                gcd.push(p);
                            }
                        }
                    });
                    load_pcd()

                    load_gcd()
                    filters = JSON.parse(d.filters);
                    var action = JSON.parse(d.action);
                    
                    $('#chk_add').prop('checked', action.isAddNewAllow);
                    $('#chk_edit').prop('checked', action.isEditAllow);
                    $('#chk_delete').prop('checked', action.isDeleteAllow); 
                    load_filters()
                    events = JSON.parse(d.events);
                    if (!events) {
                        events = [];
                    }
                    load_events()
                    actionlist = action.actionList;
                    var table = $('#table-action tbody');
                    table.empty();
                    $.each(actionlist, function (index, act) {
                        table.append(actionrow(act));
                    }); 
                    $('#duplicate_filter').val(action.duplicate_filter);
                    $('#Page_Layout_Path').val('');
                    $('#Custom_View').val('');
                    OtherData = JSON.parse(d.OtherData); 
                    $('#Page_Layout_Path').val(OtherData.Page_Layout_Path); 
                    $('#Custom_View').val(OtherData.Custom_View);
                    ispageChange = false;
                });

            })
        }

    });
