    function actionrow(act) {
        var row1 = $('<tr>').append(
            $('<td>').text(act.name),
            $('<td>').text(act.type),
            $('<td style="min-width: 95px;">').append($('<button class="btn badge rounded-pill bg-primary" onclick="editAction(this)" data-id="' + act.uniqueId + '" ><i class="bx bx-pencil"></i></button>'),
                $('<button class="btn badge rounded-pill bg-danger delete-filter ms-1"  onclick="deleteAction(this)"  data-id="' + act.uniqueId + '" ><i class="bx bx-trash"></i></button>')),
        );
        return row1;
    }
    function deleteAction(btn) {
        var id = $(btn).attr('data-id');
        Swal.fire({
            title: 'Are you sure want to delete this?',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#3085d6',
            cancelButtonColor: '#d33',
            confirmButtonText: 'Yes, delete it!',
            allowOutsideClick: false
        }).then((result) => {
            if (result.isConfirmed) {
                var indx = -1;
                $.each(actionlist, function (index, f) {
                    if (f.uniqueId == id) {
                        indx = index;
                    }
                });
                if (indx > -1) {
                    actionlist.splice(indx, 1)
                    Swal.fire(
                        'Deleted!',
                        'Your data has been deleted.',
                        'success'
                    )
                    var table = $('#table-action tbody');
                    table.empty();
                    $.each(actionlist, function (index, act) { 
                        table.append(actionrow(act));
                    });
                }
            }
        })
    };
    function editAction(btn) {
        var id = $(btn).attr('data-id'); 
        $.each(actionlist, function (index, f) {
            if (f.uniqueId == id) {
                actionindex = index; 
                $('#model-action').modal("show");
                $('#act-name').val(f.name);
                $('#act-type').val(f.type);
                $('#act-type').change();
                $('#act-icon').val(f.icon);
                $('#act-pageurl').val(f.pageurl);
                $('#act-pagetype').val(f.pagetype);
                $('#act-action-id').val(f.action_id);
                $('#act-action-id').val(f.action_id);
                $('#act-btn-text').val(f.btn_text); 
                $('#act_resp_type').val(f.act_resp_type);
