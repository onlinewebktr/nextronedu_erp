
@{
    ViewBag.Title = "Master Page Config";
}
<script src="~/Content/js/prism.js"></script>
<link href="~/Content/css/prism.css" rel="stylesheet" /> 
<style>
    #mytable td {
        padding: 0 5px;
    }

    .nav-link {
        padding: 0 .5rem;
    }
</style>
<style>

    .table-container {
        max-height: calc(100vh - 270px); /* Adjust the maximum height as needed */
        overflow-y: scroll;
    }

    .fixed-header {
        position: sticky;
        top: 0;
        background-color: #f0f0f0;
        z-index: 1;
    }
    .select2-container {
        min-width: 100%;
    }
    .pcd {
        padding-top: 0.15em !important;
        padding-bottom: 0.15em !important;
        margin-bottom: 2px;
        padding-left: 0.5em !important;
    }
</style>
<div>
    <div class="row">
        <div class="col-xxl-12">
            <div class="card m-0">
                <div class="card-body p-2">
                    <div class="row">

                        <div class="col-lg-3">
                            
                                <span  >Page  </span>
                                @Html.DropDownList("ddl_pages", (IEnumerable<SelectListItem>)ViewBag.Pages, new { @class = "form-select select" })
                             
                        </div>
                        <div class="col-lg-3">
                             
                                <span  >Table  </span>
                                @Html.DropDownList("ddl_table", new SelectList(ViewBag.Tables), "Select Table", new { @class = "form-select select" })
                             
                        </div>

                        <div class="col-lg-3">
                            
                                <span  >Title  </span>
                                @Html.TextBox("pageTitle", "", new { @class = "form-control" })
                             
                        </div>
                        <div class="col-lg-3 mb-2">
                            <span  >URL  </span>
                            <div class="input-group">
                                @Html.TextBox("pageUrl", "", new { @class = "form-control" })
                                <button id="go-to-url" class="btn btn-warning" type="button">View</button>
                            </div>
                        </div>

                        <div class="col-lg-12">


                            <ul class="nav nav-tabs nav-success mt-2" role="tablist">

                                <li class="nav-item ms-2" role="presentation">
                                    <a class="nav-link active" data-bs-toggle="tab" href="#field-customised" role="tab" aria-selected="true">
                                        <div class="d-flex align-items-center">
                                            <div class="tab-icon">
                                                <i class='bx bx-user-pin font-18 me-1'></i>
                                            </div>
                                            <div class="tab-title">Field Customization</div>
                                        </div>
                                    </a>
                                </li>
                                <li class="nav-item" role="presentation">
                                    <a class="nav-link" data-bs-toggle="tab" href="#grid-customised" role="tab" aria-selected="false">
                                        <div class="d-flex align-items-center">
                                            <div class="tab-icon">
                                                <i class='bx bx-microphone font-18 me-1'></i>
                                            </div>
                                            <div class="tab-title">Gridview Customization</div>
                                        </div>
                                    </a>
                                </li>
                                <li class="nav-item" role="presentation">
                                    <a class="nav-link" data-bs-toggle="tab" href="#tabfilters" role="tab" aria-selected="false">
                                        <div class="d-flex align-items-center">
                                            <div class="tab-icon">
                                                <i class='bx bx-filter font-18 me-1'></i>
                                            </div>
                                            <div class="tab-title">Filters</div>
                                        </div>
                                    </a>
                                </li>
                                <li class="nav-item" role="presentation">
                                    <a class="nav-link" data-bs-toggle="tab" href="#tab-event" role="tab" aria-selected="false">
                                        <div class="d-flex align-items-center">
                                            <div class="tab-icon">
                                                <i class='bx bx-filter font-18 me-1'></i>
                                            </div>
                                            <div class="tab-title">Events</div>
                                        </div>
                                    </a>
                                </li>
                                <li class="nav-item" role="presentation">
                                    <a class="nav-link" data-bs-toggle="tab" href="#tabaction" role="tab" aria-selected="false">
                                        <div class="d-flex align-items-center">
                                            <div class="tab-icon">
                                                <i class='bx bx-star font-18 me-1'></i>
                                            </div>
                                            <div class="tab-title">Action List</div>
                                        </div>
                                    </a>
                                </li>
                                <li class="nav-item" role="presentation">
                                    <a class="nav-link" data-bs-toggle="tab" href="#tab-other" role="tab" aria-selected="false">
                                        <div class="d-flex align-items-center">
                                            <div class="tab-icon">
                                                <i class='bx bx-star font-18 me-1'></i>
                                            </div>
                                            <div class="tab-title">Other Settings</div>
                                        </div>
                                    </a>
                                </li>
                                <li class="nav-item" role="presentation">
                                    <a class="nav-link" data-bs-toggle="tab" href="#tabHelp" role="tab" aria-selected="false">
                                        <div class="d-flex align-items-center">
                                            <div class="tab-icon">
                                                <i class='bx bx-help-circle font-18 me-1'></i>
                                            </div>
                                            <div class="tab-title">Help</div>
                                        </div>
                                    </a>
                                </li>
                            </ul>
                            <div class="tab-content" style=" min-height: calc(100vh - 270px); padding-top:3px">

                                <div class="tab-pane fade show active" id="field-customised" role="tabpanel">
                                    <div class="table-container">
                                        <table class="table m-0" id="mytable">
                                            <thead class="fixed-header">
                                                <tr>
                                                    <th>Column Name</th>
                                                    <th>Field Type</th>
                                                    <th>Event</th>
                                                    <th>Default Value</th>
                                                    <th>Required Field Data</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                                <div class="tab-pane fade" id="grid-customised" role="tabpanel">
                                    <div class="row">
                                        <div class="col-lg-4" style=" height: calc(100vh - 370px);">
                                            @Html.Label("Data Query (Id Column must be in query)")
                                            <textarea class="form-control" cols="20" style=" height: calc(55% - 21px);" id="DataQuery" name="DataQuery" rows="2"></textarea>
                                            @Html.Label("Sample Query")
                                            <textarea class="form-control" cols="20" style=" height: calc(45% - 21px);" id="simpleQuery" name="simpleQuery" rows="2"></textarea>
                                            <button class="btn btn-info" style="width:170px; margin-top:.5rem;" id="btn-load">Load Display Grid</button>
                                        </div>
                                        <div class="col-lg-8">
                                            <div class="table-container">
                                                <table class="table table-striped" id="grdtable">
                                                    <thead class="fixed-header">
                                                        <tr>
                                                            <th>Column Name</th>
                                                            <th>Show</th>
                                                            <th>Data Type</th>
                                                            <th>Required Data</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                    </tbody>
                                                </table>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="tab-pane fade" id="tabfilters" role="tabpanel">
                                    <div class="row">
                                        <div class="col-lg-12">
                                            <button type="button" onclick="openFilterModel()" class="btn btn-primary px-3 radius-30"><i class="bx bx-plus-circle me-3"></i> Add New Filter</button>
                                        </div>
                                        <div class="col-lg-12 mt-2">
                                            <div class="table-container">
                                                <table class="table" id="allfiltertable">
                                                    <thead class="fixed-header">
                                                        <tr>
                                                            <th style="width:30%;">Filter Name</th>
                                                            <th style="width:70%;">Data Query</th>
                                                            <th style="width:100px;">Action</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                    </tbody>
                                                </table>
                                            </div>
                                        </div>
                                    </div>

                                </div>

                                <div class="tab-pane fade" id="tab-event" role="tabpanel">
                                    <div class="row">
                                        <div class="col-lg-7">
                                            <div class="form-group me-2">
                                                <label class="form-group-text" for="ddl_field">Field Name</label>
                                                <select class="form-select" id="ddl_field" name="ddl_field"></select>
                                            </div>
                                            <div class="form-group me-2">
                                                <label class="form-group-text" for="ddl_eventtype">Event Type</label>
                                                <select class="form-select" id="ddl_eventtype" name="ddl_eventtype">
                                                    <option value="">select</option>
                                                    <option>onclick</option>
                                                    <option>onchange</option>
                                                    <option>rbt-onchange</option>
                                                    <option>script</option>
                                                </select>
                                            </div>
                                            <div class="form-group me-2">
                                                <label class="txt_event_data" for="txt_event_data">Event Data</label>
                                                <textarea class="form-control language-javascript" id="txt_event_data" style="height:200px" name="txt_event_data"></textarea>
                                                <script>
                                                    $(document).ready(function () {
                                                        Prism.highlightAll();

                                                        $('#txt_event_data').on('input', function () {
                                                            Prism.highlightAll();
                                                        });
                                                    });
                                                </script>
                                            </div>
                                            <div class="form-group mt-2">
                                                <button id="btn-add-event" class="btn btn-primary btn-sm" type="button">Add</button>
                                                <button id="btn-cencel-event" class="btn btn-dark btn-sm d-none" type="button">Cancel</button>
                                            </div>

                                        </div>
                                        <div class="col-lg-5 mt-2">
                                            <div class="table-container">
                                                <table class="table" id="table-event">
                                                    <thead class="fixed-header">
                                                        <tr>
                                                            <th style="width:20%;">Filed Name</th>
                                                            <th style="width: 20%;">Event Type</th>
                                                            <th style="width:60%;">Event Data</th>
                                                            <th style="width:100px;">Action</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                    </tbody>
                                                </table>
                                            </div>
                                        </div>
                                    </div>

                                </div>


                                <div class="tab-pane fade" id="tabaction" role="tabpanel">
                                    <div class="row">
                                        <div class="col-lg-12">
                                            <button type="button" onclick="openActionModel()" class="btn btn-primary px-3 radius-30"><i class="bx bx-plus-circle me-3"></i> Add New Action</button>
                                        </div>
                                        <div class="col-lg-12 mt-2">
                                            <div class="table-container">
                                                <table class="table" id="table-action">
                                                    <thead class="fixed-header">
                                                        <tr>
                                                            <th>Action Name</th>
                                                            <th>Action Type</th> 
                                                            <th>Action</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                    </tbody>
                                                </table>
                                            </div>
                                        </div>
                                    </div>

                                </div>


                                <div class="tab-pane fade" id="tab-other" role="tabpanel">

                                    <div class="row">
                                        <div class="col-xl-12 mt-3">
                                            <div class="row">
                                                <div class="col-lg-3 mb-2">
                                                    <div class="input-group">
                                                        <span class="btn btn-dark">Type  </span>
                                                        @Html.DropDownList("pageType", new SelectList(new String[] { "Form", "Report","Single Data Form Only" }), new { @class = "form-select" })
                                                    </div>
                                                </div>
                                                <div class="col-lg-3 mb-2">
                                                    <div class="input-group">
                                                        <span class="btn btn-dark">Form Type  </span>
                                                        @Html.DropDownList("ddl_formtype", new SelectList(new String[] { "LeftRight", "TopDown","PopUp" }), new { @class = "form-select" })
                                                    </div>
                                                </div>
                                                <div class="col-lg-3 mb-2">
                                                    <div class="input-group">
                                                        <span class="btn btn-dark">Action  </span>
                                                        <div class="form-control ps-1 pe-1">


                                                            <span class="btn btn-info p-0 ps-1">
                                                                @Html.CheckBox("chk_add", true)
                                                                <label for="chk_add"> <i class='bx bx-plus'></i></label>
                                                            </span>
                                                            <span class="btn btn-warning p-0 ps-1">
                                                                @Html.CheckBox("chk_edit", true)
                                                                <label for="chk_edit"> <i class='bx bx-edit-alt'></i></label>
                                                            </span>
                                                            <span class="btn btn-danger p-0 ps-1">
                                                                @Html.CheckBox("chk_delete", true)
                                                                <label for="chk_delete"> <i class='bx bx-trash'></i></label>
                                                            </span>

                                                        </div>
                                                    </div>
                                                </div>


                                                <div class="col-lg-3 mb-2">
                                                    <div class="input-group">
                                                        <span class="btn btn-dark">Method Id </span>
                                                        @Html.TextBox("methodId", "", new { @class = "form-control" })
                                                    </div>
                                                </div>

                                                @Html.LabelEditor("duplicate_filter", "text", "Duplicate Column Filters (Comma Seperated)",divCssClass: "col-lg-6")
                                                @Html.LabelEditor("Page_Layout_Path", "text", "Page Layout Path", divCssClass: "col-lg-3")
                                                @Html.LabelEditor("Custom_View", "text", "Custom View Name", divCssClass: "col-lg-3")
                                                <div class="col-lg-12 my-2">
                                                    <button type="button" class="btn btn-primary" id="btn-export">Export</button>
                                                    <script>
                                                        $('#btn-export').click(function () {
                                                            var pageId = $('#ddl_pages').val();
                                                            window.open("../../hr/export/" + pageId,"_blank")
                                                           
                                                            //var data = { data: { pageId: pageId } }
                                                            //gowithData("../../hr/data/export", 'POST', JSON.stringify(data), function (resp) {
                                                            //    console.log(resp);
                                                            //});
                                                        });
                                                    </script>
                                                </div>
                                            </div>
                                        </div>
                                        @*<div class="col-xl-8">
                    <div class="table-container">
                        <table class="table table-striped" id="actiontable">
                            <thead class="fixed-header">
                                <tr>
                                    <th>Column Name</th>
                                    <th>Display</th>
                                    <th>Data Type</th>
                                    <th>Required Data</th>
                                </tr>
                            </thead>
                            <tbody>
                            </tbody>
                        </table>
                    </div>
                </div>*@
                                    </div>
                                </div>


                                <div class="tab-pane fade  " id="tabHelp" role="tabpanel">
                                    <ul>
                                        <li>
                                            To User Filter Veriable Name in query <strong>{[Veriable Name].PropertyName}</strong>
                                            <ul>
                                                <li>
                                                    Ex 1 . select * from tablename where name='{[User Name].Text}'
                                                </li>
                                                <li>   Ex 2. select * from tablename where idate='{[Event Date].Idate}'</li>
                                            </ul>
                                        </li>
                                        <li>
                                            List Of Properties
                                            <ul>
                                                <li>1 . DatePicker : Idate,Format("")</li>
                                                <li>2 . DDL : Text,Value</li>
                                                <li>3 . AutoCompleteBox : Text</li>
                                                <li>4 . TextBox : Text</li>
                                            </ul>

                                        </li>
                                        <li>
                                            List Of Predefind variable
                                            <ul>
                                                <li>1 . CurrentIdate : {Idate}         </li>
                                                <li>1 . CurrentDate : {Date.Format("")}</li>
                                                <li>1 . CurrentUserId : {UserId}       </li>
                                                <li>1 . AnySessionValye : {Session[""]}</li>
                                            </ul>
                                        </li>
                                    </ul>

                                </div>
                            </div>
                        </div>
                    </div>


                </div>
                <div class="card-footer">
                    <div class="row">
                        <div class="col-lg-4">

                        </div>
                        <div class="col-lg-8" style="text-align:right">
                            <button class="btn btn-primary" style="width:120px;" onclick="save_data()">Save</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="model-filter" tabindex="-1" aria-hidden="true" data-bs-backdrop="static" data-bs-keyboard="false">
        <div class="modal-dialog modal-xl">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Filter</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-lg-4">

                            <div class="input-group mb-1">
                                <span class="btn-light btn" style="width: 110px; border-color: #d0d0d0; ">Name  </span>
                                <input id="filter-name" class="form-control" />
                            </div>
                            <div class="input-group mb-1">
                                <span class="btn-light btn  " style="width: 110px; border-color: #d0d0d0; ">Type  </span>
                                @Html.DropDownList("filter-type", "DDL,Auto CompleteBox,DatePicker,DateRage,TextBox", "Select", new { @class = "form-select" })
                            </div>
                            <div class="input-group mb-1 d-none" id="div-data-type">
                                <span class="btn-light btn  " style="width: 110px; border-color: #d0d0d0; ">Data Type  </span>
                                @Html.DropDownList("filter-datatype", "Static,Static Key Value,Months,Year,SQL,On Change", "Select", new { @class = "form-select" })
                            </div>
                            <div class="input-group mb-1 d-none" id="div-onchange">
                                <span class="btn-light btn  " style="width: 110px; border-color: #d0d0d0; ">On Change  </span>
                                @Html.DropDownList("filter-onchange", "N/A", "Select", new { @class = "form-select" })
                            </div>
                            <div class="d-none" id="div-data-query">
                                @Html.Label("Data Query")
                                <textarea class="form-control" cols="20" style=" height: 50px;" id="filter-dataquery" rows="2"></textarea>
                            </div>
                            <button class="btn btn-info  me-2" id="btn-filter" style="margin-top:.25rem;">Add</button>
                            <button class="btn btn-dark d-none" id="btn-filter-cancel" style="margin-top:.25rem;">Cancel</button>
                        </div>
                        <div class="col-lg-8">
                            <div class="table-container">
                                <table class="table table-striped" id="filtertable">
                                    <thead class="fixed-header">
                                        <tr>
                                            <th>Name</th>
                                            <th>Type</th>
                                            <th>Data Type</th>
                                            <th>On Change</th>
                                            <th>Data - Query</th>
                                            <th style="width:100px;">Action</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer p-0 d-block">
                    <div class="row pb-2">
                        <div class="col-lg-3">
                            <span>Filter Name  </span>
                            <input id="filter-serial-name" type="text" class="form-control" />
                            <span>Filter Button Name </span>
                            <input id="filter-btn-name" type="text" value="Find" class="form-control" />
                        </div>
                        <div class="col-lg-6">
                            <span>Filter Data Query </span>
                            <textarea id="filter-grid-dataquery" class="form-control"></textarea>
                        </div>
                        <div class="col-lg-3 pt-5">
                            <button type="button" id="btn-model-filter" class="btn btn-primary me-2 btn-lg" style="width:100px">Submit </button>
                            <button type="button" class="btn btn-secondary  btn-lg" data-bs-dismiss="modal">Close</button>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
    
    <div class="modal fade" id="model-action" tabindex="-1" aria-hidden="true" data-bs-backdrop="static" data-bs-keyboard="false">
        <div class="modal-dialog modal-xl">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Action</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-lg-12">
                            <div class="row">
                                <div class="col-4">
                                    <div class="input-group mb-1">
                                        <span class="btn-light btn" style="width: 130px; border-color: #d0d0d0; ">Action Name  </span>
                                        <input id="act-name" class="form-control" />
                                    </div>
                                </div>
                                <div class="col-4">
                                    <div class="input-group mb-1">
                                        <span class="btn-light btn  " style="width: 130px; border-color: #d0d0d0; ">Action Type  </span>
                                        @Html.DropDownList("act-type", "Url,Form,CustomForm", "Select", new { @class = "form-select" })
                                    </div>
                                </div>
                                <div class="col-4">
                                    <div class="input-group mb-1">
                                        <span class="btn-light btn" style="width: 130px; border-color: #d0d0d0; ">Icon  </span>
                                        <input id="act-icon" class="form-control" />
                                    </div>
                                </div>
                                <div class="col-4 act-urlpnl">
                                    <div class="input-group mb-1">
                                        <span class="btn-light btn" style="width: 130px; border-color: #d0d0d0; ">Page Url  </span>
                                        <input id="act-pageurl" class="form-control" />
                                    </div>
                                </div>
                                <div class="col-4 act-urlpnl">
                                    <div class="input-group mb-1  " id="div-data-type">
                                        <span class="btn-light btn  " style="width: 130px; border-color: #d0d0d0; ">Page Type  </span>
                                        @Html.DropDownList("act-pagetype", "Same Page,New Tab,PopUp", "Select", new { @class = "form-select" })
                                    </div>
                                </div>
                                <div class="col-4   act-formpnl act-cust-form">
                                    <div class="input-group mb-1">
                                        <span class="btn-light btn" style="width: 130px; border-color: #d0d0d0; ">Button Text  </span>
                                        <input id="act-btn-text" class="form-control" />
                                    </div>
                                </div>
                                <div class="col-4 act-formpnl act-cust-form">
                                    <div class="input-group mb-1   "  >
                                        <span class="btn-light btn  " style="width: 130px; border-color: #d0d0d0; ">Method Id </span>
                                        <input id="act-action-id" class="form-control" />
                                    </div>
                                </div> 
                                <div class="col-4">
                                    <div class="input-group mb-1"  >
                                        <span class="btn-light btn  " style="width: 150px; border-color: #d0d0d0; ">Responce Type </span>
                                        <select id="act_resp_type" class="form-select" >
                                            <option value="status">Status</option>
                                            <option value="remove">Remove Row</option>
                                            <option value="reload">Reload Data</option>
                                        </select>
                                    </div>
                                </div> 
                            </div>
                             

                        </div>

                        <div class="col-lg-12 table-container d-none  act-formpnl">
                            <table class="table table-striped" id="act-table">
                                <thead class="fixed-header">
                                    <tr>
                                        <th>Column Name</th>
                                        <th>Show</th> 
                                    </tr>
                                </thead>
                                <tbody>
                                </tbody>
                            </table>

                        </div>
                        <div class="col-lg-12 table-container d-none  act-cust-form">
                            <table class="table table-striped" id="act-cust-table">
                                <thead class="fixed-header">
                                    <tr>
                                        <th>Field Name</th>
                                        <th>Field Type</th>
                                        <th>On Changed</th>
                                        <th>Default</th>
                                        <th>Field Config Data</th>
                                    </tr>
                                </thead>
                                <tbody>
                                </tbody>
                            </table>
