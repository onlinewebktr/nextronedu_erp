            $('<td>').prop('style', 'width:12%;').append('<input  type="text" class="form-control px-1 py-0" style="margin-top: 0px; font-size: 14px;"  placeholder="default value"  value="' + p.defaultValue + '" id="txt_deafult_' + p.columnName + '" />', '<input  type="text" class="form-control px-1 py-0" style="margin-top: 4px; font-size: 14px;" value="' + p.cssclass + '" placeholder="col-lg-6" id="txt_css_' + p.columnName + '" />'),
