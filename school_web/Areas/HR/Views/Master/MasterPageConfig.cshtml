        );
        if (p.onChanged) {
            ddl_event.val(p.onChangedField);
        }
        return row
    };
    function event_changed(chk) {

        if ($(chk).is(':checked')) {
            // Checkbox is checked
            $('#' + $(chk).attr("data-id")).prop('disabled', false);
            // Perform some actions
        } else {
            $('#' + $(chk).attr("data-id")).prop('disabled', true);
            $('#' + $(chk).attr("data-id")).val('');
        }
    };
    $('#go-to-url').click(function () {
        var url = '../hr/'+$('#pageUrl').val();
        window.open(url, '_blank');
    })
