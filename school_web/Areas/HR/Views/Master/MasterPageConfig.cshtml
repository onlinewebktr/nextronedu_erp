    function displayText(string) {
        let separatedString = "";
        let currentWord = "";

        for (let i = 0; i < string.length; i++) {
            const char = string[i];
            if (char.toUpperCase() === char || char === "_") {
                if (currentWord) {
                    separatedString += currentWord + " ";
                    currentWord = "";
                } else if (char === "_") {
                    separatedString += " ";
                }
            }
            if (char !== "_") {
                currentWord += char;
            }
        }

        if (currentWord) {
            separatedString += currentWord;
        }

        const capitalizedString = separatedString.replace(/_/g, "").replace(/\b\w/g, function (match) {
            return match.toUpperCase();
        });

        return capitalizedString;
    }

