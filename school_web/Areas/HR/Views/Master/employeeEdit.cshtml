        <script>
            $(function () {
                //$('#lngs input[type="checkbox"]').prop('disabled', true);
                gotoPage(0);
                bindEmployeeList();
                gowithData("../../hr/data/ddl", "POST", JSON.stringify({ data: { type: 'GradeDesignation' } }), function (resp) {
                    if (!resp.error) {
                        var ddl = $('#Grade');
                        $("#Grade option:not(:first)").remove();
                        $.each(resp.grade, function (i, item) {
                            ddl.append($("<option>").text(item.grade_name).val(item.grade_id));
                        });
                        ddl.val('@emp.Grade_id')
                        ddl = $('#Department');
                        $("#Department option:not(:first)").remove();
                        $.each(resp.department, function (i, item) {
                            ddl.append($("<option>").text(item.name).val(item.department_id));
                        });
                        ddl.val('@emp.Department_id')
                        ddl = $('#Designation');
                        $("#Designation option:not(:first)").remove();
                        $.each(resp.designation, function (i, item) {
                            ddl.append($("<option>").text(item.name).val(item.Designation_id));
                        });
                        ddl.val('@emp.Designation_id')
                    }
                })

                gowithData("../../hr/data/salary_structure_apply", "POST", JSON.stringify({ data: { App_id: '@em.Apply_id' } }), function (resp) {
                    if (!resp.error) {

                        deductions = resp.deduction_head;
                        incomes = resp.income_heads;
                        bind_income_table()
                        calulate_deduction();
                        bind_deduction_table();
                        var basic = 0
                        var gross = 0;
                        var total_deduct = 0;
                        var emp_contri = 0;
                        $.each(incomes, function (i, item) {
                            if (item.IsBasic == 'Yes') {
                                basic += parseFloat(item.inc)
                            }
                            gross += parseFloat(item.inc)
                        });
                        $.each(deductions, function (i, item) {
                            total_deduct += item.deduct
                            emp_contri += item.deduct_emp
                        });
                        $('#Gross').text(gross);
                        $('#Net_Gross_Salaray').val(gross);
                        $('#Deduction').text(total_deduct);
                        $('#lblGross').text(gross);
                        $('#lblDeduction').text(total_deduct);
                        $('#lblNet_Salary').text(gross - total_deduct);
                        $('#lblEmployeer_Contribution').text(emp_contri);
                        $('#lblCTC_month').text(gross + emp_contri);
                        $('#lblCTC_year').text((gross + emp_contri) * 12);
                    }
                })

                get_qualification();
            })
            function get_qualification() {
                gowithData("../../hr/data/get_qualification", "POST", JSON.stringify({ data: { App_id: '@em.Apply_id', Emp_code: '@emp.Emp_Code' } }), function (resp) {
                    if (!resp.error) {

                        console.log(resp.data);
                        $.each(resp.data, function (i, d) {
                            var cls = "metric";
                            if (d.Qualification == "Inter/+2") {
                                cls = "inter";
                            }
                            else if (d.Qualification == "Graduation") {
                                cls = "grad";
                            }
                            else if (d.Qualification == "Post Graduation") {
                                cls = "pg";
                            }
                            else if (d.Qualification == "PHD") {
                                cls = "mp";
                            }
                            else if (d.Qualification == "MD") {
                                cls = "md";
                            }
                            else if (d.Qualification == "MBBS") {
                                cls = "mbbs";
                            }
                            else if (d.Qualification == "B.Ed") {
                                cls = "b_ed";
                            }
                            else if (d.Qualification == "M.Ed") {
                                cls = "m_ed";
                            }

                            else if (d.Qualification == "Any Other") {
                                cls = "oth";
                            }
                            $(`#${cls}_sub`).val(d.Main_Subjects);
                            $(`#${cls}_school`).val(d.School_College);
                            $(`#${cls}_board`).val(d.Board_University);
                            $(`#${cls}_year`).val(d.Year_of_Passing);
                            $(`#${cls}_marks`).val(d.Percentage_of_Marks);
                            $(`#${cls}_division`).val(d.Division);
                            $(`#${cls}_marks_obtain`).val(d.Marks_obtain);
                            $(`#${cls}_f_marks`).val(d.Full_Marks);
                        });
                        var ds = JSON.parse(resp.exp_data[0].Emp_Experience);
                        $.each(ds, function (i, d) {
                            var a = i + 1;
                            $(`#org_name_${a}`).val(d.org_name);
                            $(`#org_designation_${a}`).val(d.Designation);
                            $(`#org_duration_${a}`).val(d.Employement_Duration);
                            $(`#org_salary_${a}`).val(d.Salary);
                            $(`#org_leaving_${a}`).val(d.Leaving_Reason);
                        });
                    }
                })
            }
            $("#Department").on("change", function () {
                var data = { type: 'designation', DepartmentId: $('#Department').val() };
                gowithData("../../hr/data/ddl", "POST", JSON.stringify({ data: data }), function (resp) {
                    if (!resp.error) {
                        var ddl= $('#Designation');
                        $("#Designation option:not(:first)").remove();
                        $.each(resp.data, function (i, item) {
                            ddl.append($("<option>").text(item.name).val(item.Designation_id));
                        });
                    }
                })
            })

            function bindEmployeeList() {
                var data = { type: 'name_initital' };
                gowithData("../../hr/data/ddl", "POST", JSON.stringify({ data: data }), function (resp) {
                    if (!resp.error) {
                        var ddl = $('#Salutation');
                        $("#Salutation option:not(:first)").remove();
                        $.each(resp.data, function (i, item) {
                            ddl.append($("<option>").text(item.Initial_name).val(item.Initial_id));
                        });
                        ddl.val('@em.Salutation')
                    }
                })
            }
            function gotoPage(eid) {
                $("#current_tab").val(eid);
                $("#stepper-div").children().removeClass("active");
               $("#stepper-div").children().removeClass("completed");
                $.each($("#stepper-div").children(), function (index, el) {
                    var di = '#' + $(el).attr('data-id')
                    if (index < eid) {
                        $(el).addClass('completed')
                        $(di).hide();
                    }
                    else if (index == eid) {
                        $(el).addClass('active')
                        $(di).show();
                    }
                    else {
                        $(di).hide();
                        $(el).removeClass('completed')
                        $(el).removeClass('active')
                    }

                })
                $('#btn-back').hide();
                $('#btn-next').hide();
                $('#btn-submit').hide();
                if (eid > 0) {
                    $('#btn-back').show();
                }
                if (eid < 7) {
                    $('#btn-next').show();
                }
                if (eid == 7) {
                    $('#btn-submit').show();
                }
            }
            $('#btn-back').click(function () {
                var currentValue = parseInt($("#current_tab").val());
                if (currentValue > 0) {
                    currentValue = currentValue - 1;
                    gotoPage(currentValue);
                }

            })
            $('#btn-next').click(function () {

                var currentValue = parseInt($("#current_tab").val());
                if (currentValue == 0) {

                    console.log("Print" + $("#passport_photo").val())

                    if ($("#Salutation").val() == "" || $("#Salutation").val() == "Select" || $("#Salutation").val() == null) {
                        alertError("Salutation is required");
                        return false;
                    }
                    if ($("#First_Name").val() == "") {
                        alertError("First Name is required");
                        return false;
                    }
                    if ($("#Emailid").val() == "") {
                        alertError("Email is required");
                        return false;
                    }
                    if ($("#Date_birthday").val() == "") {
                        alertError("Date of birth is required");
                        return false;
                    }
                    if ($("#Gender").val() == "" || $("#Gender").val() == "Select" || $("#Gender").val() == null) {
                        alertError("Gender is required");
                        return false;
                    }

                    if ($("#Religion").val() == "" || $("#Religion").val() == "Select" || $("#Religion").val() == null) {
                        alertError("Religion is required");
                        return false;
                    }
                    if ($("#Nationality").val() == "" || $("#Nationality").val() == "Select" || $("#Nationality").val() == null) {
                        alertError("Nationality is required");
                        return false;
                    }
                    if ($("#Marital_Status").val() == "" || $("#Marital_Status").val() == "Select" || $("#Marital_Status").val() == null) {
                        alertError("Marital Status is required");
                        return false;
                    }
                    //if ($("#passport_photo").val() == "") {
                    //    alertError("A Passport Size Photo is required");
                    //    return false;
                    //}
                    //if ($("#Signature").val() == "") {
                    //    alertError("Signature is required");
                    //    return false;
                    //}
                }
                if (currentValue == 1) {

                    if ($("#Address_CA").val() == "") {
                        alertError("Address is required");
                        return false;
                    }
                    if ($("#City_CA").val() == "") {
                        alertError("City is required");
                        return false;
                    }
                    if ($("#State_CA").val() == "") {
                        alertError("State is required");
                        return false;
                    }
                    if ($("#Pincode_CA").val() == "") {
                        alertError("Pincode is required");
                        return false;
                    }
                    if ($("#address_pa").val() == "") {
                        alertError("Permanent Address is required");
                        return false;
                    }
                    if ($("#mobile_no_CA").val() == "") {
                        alertError("Mobile No is required");
                        return false;
                    }

                }

                if (currentValue == 2) {

                    if ($("#fathername").val() == "") {
                        alertError("Father Name is required");
                        return false;
                    }



                }
                if (currentValue == 3) {



                }
                if (currentValue == 4) {
                    if ($("#Proficiency_In_Computer").val() == "" || $("#Proficiency_In_Computer").val() == "Select" || $("#Proficiency_In_Computer").val() == null) {
                        alertError("Computer Proficiency is required");
                        return false;
                    }
                }
                if (currentValue == 5) {


                    if ($("#BloodGroup").val() == "" || $("#BloodGroup").val() == "Select" || $("#BloodGroup").val() == null) {
                        alertError("Plese Select  Blood Group");
                        return false;
                    }
                     if ('@My.isSchool' == 'True' && $('#User_Type').val() == "") {
                          alertError("Please select user type");
                          return false;
                }

                    if ($("#Password").val() == "") {
                        alertError("Please Enter HRMS Password");
                        return false;
                    }
                    if ($("#date_of_joining").val() == "") {
                        alertError("Please Enter Joining Date");
                        return false;
                    }
                    if (!$("#chk_emp").prop('checked')) {
                        if ($("#Employee_Code").val() == "") {
                            alertError("Please Enter Employee Code");
                            return false;
                        }
                    }

                }

                currentValue = currentValue + 1;
                gotoPage(currentValue);

            })
            $('#chk_emp').change(function () {
                var currentValue = $("#chk_emp").prop('checked');

                if (currentValue) {
                    $('#Employee_Code').prop("disabled",true);
                    $('#Employee_Code').val('');
                }
                else {
                    $('#Employee_Code').prop("disabled", false);
                }
            })
            var documents = [];
            $('#btn-doc-upload').click(function () {
                var Doc_Name=  $("#Doc_Name").val()
                var choose_file = $("#choose_file").val()
                if (Doc_Name == "") {
                    alertError("Please Enter Document Name")
                }
                else if (choose_file == "") {
                    alertError("Please Select a file")
                }
                else {
                    var data = { Doc_Name: Doc_Name, file: choose_file }
                    documents.push(data);
                    bind_doc_table();
                    $("#Doc_Name").val("");
                    $("#choose_file").val("");
                    $("#img_choose_file").hide();
                }
            })
            $('#tbl-docs').on('click', '.delete-button',function () {
                var ind = parseInt($(this).data('id'));

                alertConfirm("Are you sure want to delete this?", function(){
                    documents.splice(ind, 1)
                    bind_doc_table();
                })
            })

            function bind_doc_table() {
                var tableBody = $('#tbl-docs tbody');
                tableBody.empty();
                $.each(documents, function (index, d) {
                    var div = $('<div>').addClass("d-flex align-items-center")
                    div.append(
                        $('<button>').addClass("delete-button btn").attr("data-id", index).html("<i class='bx bx-trash'></i>"),
                    )
                    var td = $('<td>').append(div).width("55px");
                    var row = $('<tr>').append(
                        $('<td>').text(index+1),
                        $('<td>').text(d.Doc_Name),
                        $('<td>').append(`<a href="${d.file}"   download="${d.Doc_Name}"   ><img src="${d.file}" onerror="this.src='../../Content/Images/Icons/file.png';" class="img-thumbnail" style="height: 70px;" id="img_choose_file"></a>`),
                        td,
                    );
                    tableBody.append(row);
                });
            }


            $('#myForm').submit(function (e) {
                e.preventDefault();
                if ($("#Grade").val() == "") {
                    alertError("Please Select Grade");
                    return false;
                }
                if ($("#Department").val() == "") {
                    alertError("Please Select Department");
                    return false;
                }
                if ($("#Designation").val() == "") {
                    alertError("Please Select Designation");
                    return false;
                }
                var formArray = $(this).serializeArray();
                var formData = {};
                $(formArray).each(function (index, obj) {
                    formData[obj.name] = obj.value;
                });
                $('#myForm input[type="checkbox"]').each(function () {
                    formData[this.name] = $(this).prop('checked');
                });
                formData["Gross"] = $('#lblGross').text();
                formData["Deduction"] = $('#lblDeduction').text();
                formData["Net_Salary"] = $('#lblNet_Salary').text();
                formData["Employeer_Contribution"] = $('#lblEmployeer_Contribution').text();
                formData["CTC_month"] = $('#lblCTC_month').text();
                formData["CTC_year"] = $('#lblCTC_year').text();

                //$('#myForm :disabled').each(function () {
                //    formData[this.name] = $(this).val()
                //});
                var data = { formdata: JSON.stringify(formData)};
                data.incomes = JSON.stringify(incomes);
                data.deductions = JSON.stringify(deductions) ;
                data.documents = JSON.stringify(documents) ;
                data.designation = $('#Designation option:selected').text();
                data.applyId = $('#applyId').val();
                submitdata("../../hr/save/editemployee", JSON.stringify({data: data}), function (resp) {
                    if (!resp.error) {
                        window.close();
                    } else {
                        if (resp.message.indexOf("change")) {
                            alertConfirm(resp.message, function () {
                                data.changeIt = "1";
                                submitdata("../../hr/data/editemployee", JSON.stringify({ data: data }), function (resp) {
                                    if (!resp.error) {
                                        window.close();
                                    }
                                })
                            })
                        }
                    }
                });
            })
            function formatDate(inputDate) {
                var date = new Date(inputDate);
                var formattedDate = date.toLocaleDateString('en-CA', { year: 'numeric', month: '2-digit', day: '2-digit' }).replace(/\//g, '-');
                return formattedDate;
            }
        </script>
        <script src="~/Content/js/salary_performa_1.js"></script>


        <script>

            var deductions = [];
            var incomes = [];
            var basic = 0;
            $("#Grade").on("change", function () {
                var grade = $(this).val();
                gowithData("../../hr/data/ddl", "POST", JSON.stringify({ data: { type: 'IncomeDeduct', grade: grade } }), function (resp) {
                    if (!resp.error) {
                        $.each(incomes, function (i, item) {
                            if (item.IsBasic == 'Yes') {
                                basic = item.inc;
                            }
                        });
                        deductions = resp.deduction;
                        incomes = resp.income;
                        $.each(incomes, function (i, item) {
                            if (item.IsVeriable == 'Yes') {
                                var amount = get_calculation_on(item.CalculationBassedOn)
                                if (item.PercentageValue.includes('%')) {
                                    item.inc = amount * parseFloat(item.PercentageValue) / 100;
                                }
                                else {
                                    item.inc = parseFloat(item.PercentageValue)
                                }
                            }
                            else {
                                item.inc = parseFloat(item.PercentageValue)
                            }
                            if (item.IsBasic == 'Yes') {
                                item.inc = basic;
                            }
                        });
                        $.each(deductions, function (i, item) {
                            item.isEnable = true;
                        });
                        calulate_deduction();
                        bind_income_table()
                        bind_deduction_table()
                    }
                })
            })


        </script>

