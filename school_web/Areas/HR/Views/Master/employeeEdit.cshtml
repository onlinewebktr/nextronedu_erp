                    <div class="p-4 border rounded" style="padding: 0px 0px 20px 0px !important; float: left; width: 100%;" id="page_communication_address_info" visible="false">
                        <h2 class="form-ttleS">Communication Address</h2>

                        <div class="g-3 needs-validation" style="padding: 0px 10px 10px 10px;">

                            <div class="row">
                                @Html.LabelEditor("Address_CA", "text", "Address", em.Address_CA, isRequired: true, divCssClass: "col-md-6")
                                @Html.LabelEditor("City_CA", "text", "City", em.City_CA, isRequired: true, divCssClass: "col-md-3")
                                @Html.LabelEditor("State_CA", "text", "State", em.State_CA, isRequired: true, divCssClass: "col-md-3")
                                @Html.LabelEditor("Pincode_CA", "text", "Pin Code", em.Pincode_CA, isRequired: true, divCssClass: "col-md-3")
                                @Html.LabelEditor("mobile_no_CA", "text", "Mobile No", em.mobile_no_CA, isRequired: true, divCssClass: "col-md-3")
                                @Html.LabelEditor("Residence_telephone_no_CA", "text", "Residence Telephone No", em.Residence_telephone_no_CA, divCssClass: "col-md-3")


                            </div>


                            <div class="form-group form-check p-3 mx-3">
                                <input style="font-size:18px; color:#000" type="checkbox" class="form-check-input" id="chk_same_check_box" onchange="handleCheckboxChange()" OnCheckedChanged="chk_same_check_box_CheckedChanged" AutoPostBack="true">
                                <label class="form-check-label" for="exampleCheck1">Permanent Address (Check this box if Communication Address & Permanent Address are the same.)</label>
                            </div>

                            <script>
                                function handleCheckboxChange() {
                                    var checkbox = document.getElementById("chk_same_check_box");
                                    var addressCA = document.getElementById("Address_CA");
                                    var pAddressCA = document.getElementById("address_pa");
                                    var City_CA = document.getElementById("City_CA");
                                    var State_CA = document.getElementById("State_CA");
                                    var Pincode_CA = document.getElementById("Pincode_CA");
                                    var city_pa = document.getElementById("city_pa");
                                    var state_pa = document.getElementById("state_pa");
                                    var pin_pa = document.getElementById("pin_pa");

                                    if (checkbox.checked) {
                                        // If checkbox is checked, copy values from Address_CA to P_Address_CA
                                        pAddressCA.value = addressCA.value;
                                        city_pa.value = City_CA.value;
                                        state_pa.value = State_CA.value;
                                        pin_pa.value = Pincode_CA.value;
                                    } else {
                                        // If checkbox is unchecked, you may want to clear P_Address_CA or handle it differently
                                        pAddressCA.value = "";
                                        city_pa.value = "";
                                        state_pa.value = "";
                                        pin_pa.value = "";
                                    }
                                }
                            </script>

                            <div class="row">

                                @Html.LabelEditor("address_pa", "text", "Address", em.address_pa, isRequired: true, divCssClass: "col-md-6")
                                @Html.LabelEditor("city_pa", "text", "City", em.city_pa, isRequired: true, divCssClass: "col-md-3")
                                @Html.LabelEditor("state_pa", "text", "State", em.state_pa, isRequired: true, divCssClass: "col-md-3")
                                @Html.LabelEditor("pin_pa", "text", "Pin Code", em.pin_pa, isRequired: true, divCssClass: "col-md-3")



                            </div>


                        </div>


                    </div>

                    <div class="p-4 border rounded" style="padding: 0px 0px 20px 0px !important; float: left; width: 100%;" id="page_family_info" visible="false">
                        <h2 class="form-ttleS">Family Information</h2>
                        <div class="row">

                            @Html.LabelEditor("fathername", "text", "Father Name",emp.Father_Name, isRequired: true, divCssClass: "col-md-3")
                            @Html.LabelEditor("father_occupation", "text", "Father Occupation",em.father_occupation, divCssClass: "col-md-3")
                            @Html.LabelEditor("mother_name", "text", "Mother Name",em.mother_name, divCssClass: "col-md-3")
                            @Html.LabelEditor("mother_occupation", "text", "Mother Occupation",em.mother_occupation, divCssClass: "col-md-3")


                            @Html.LabelEditor("Spouse_name", "text", "Spouse Name",em.Spouse_name, divCssClass: "col-md-3")
                            @Html.LabelEditor("spouse_qualification", "text", "Spouse's Qualification",em.spouse_qualification, divCssClass: "col-md-3")
                            @Html.LabelEditor("spouse_profession", "text", "Spouse's Profession",em.spouse_profession, divCssClass: "col-md-3")
                            @Html.LabelEditor("Spouses_job_is_transferable", "ddl", "Spouse's job is transferable", em.Spouses_job_is_transferable, divCssClass: "col-md-3", ddl_comma_seperated: "YES,NO,N/A")
                            @Html.LabelEditor("spouse_organization", "text", "Spouse's Organization",em.spouse_organization, divCssClass: "col-md-6")
                            @Html.LabelEditor("spouse_designation", "text", "Spouse's Designation",em.spouse_designation, divCssClass: "col-md-3")



                        </div>
                        <h2 class="form-ttleS">Children Information</h2>
                        <div class="row">
                            @Html.LabelEditor("chiled_name1", "text", "Name",em.chiled_name1, divCssClass: "col-md-4")
                            @Html.LabelEditor("chiled_gender1", "ddl", "Gender", em.chiled_gender1, divCssClass: "col-md-4", ddl_comma_seperated: "MALE,FEMALE, THIRD GENDER")
                            @Html.LabelEditor("chiled_age1", "number", "Age", em.chiled_age1, divCssClass: "col-md-4")

                            @Html.LabelEditor("chiled_name2", "text", "Name", em.chiled_name2, divCssClass: "col-md-4")
                            @Html.LabelEditor("chiled_gender2", "ddl", "Gender", em.chiled_gender2, divCssClass: "col-md-4", ddl_comma_seperated: "MALE,FEMALE, THIRD GENDER")
                            @Html.LabelEditor("chiled_age2", "number", "Age", em.chiled_age3, divCssClass: "col-md-4")

                            @Html.LabelEditor("chiled_name3", "text", "Name", em.chiled_name3, divCssClass: "col-md-4")
                            @Html.LabelEditor("chiled_gender3", "ddl", "Gender", em.chiled_gender3, divCssClass: "col-md-4", ddl_comma_seperated: "MALE,FEMALE, THIRD GENDER")
                            @Html.LabelEditor("chiled_age3", "number", "Age", em.chiled_age3, divCssClass: "col-md-4")

                        </div>


                    </div>

                    <div class="p-4 border rounded" style="padding: 0px 0px 20px 0px !important; float: left; width: 100%;" id="Page_Academic_Maped" visible="false">

                        <h2 class="form-ttleS">Academic Qualification</h2>
                        <div class="row">
                            <div class="col-12">

                                <table class="table-bordered" id="#lngs" style="width: 100%;">
                                    <thead>
                                        <tr>
                                            <th>Qualification</th>
                                            <th>Main Subjects</th>
                                            <th>School/College</th>
                                            <th>Board/University</th>
                                            <th>Year of Passing</th>
                                            <th>Full Marks</th>
                                            <th>Marks Obtained</th>
                                            <th>Percentage of Marks</th>
                                            <th>Division</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @{ var dict = new Dictionary<string, string>();
                                                        dict["metric"] = "High School/10th";
                                                        dict["inter"] = "Inter/+2";
                                                        dict["grad"] = "Graduation";
                                                        dict["pg"] = "Post Graduation";
                                                        dict["mp"] = "PHD";
                                                        if (My.isHospital)
                                                        {
                                                            dict["md"] = "MD";
                                                            dict["mbbs"] = "MBBS";
                                                        }
                                                        else if (My.isSchool)
                                                        {
                                                            dict["b_ed"] = "B.Ed";
                                                            dict["m_ed"] = "M.Ed";
                                                        }
                                                        else
                                                        {

                                                        }
                                                        dict["oth"] = "Any Other";
                                                        foreach (var key in dict.Keys)
                                                        {
                                            <tr>
                                                <th>@dict[key]</th>
                                                <th> @Html.TextBox(@key + "_sub", "", new { @class = "form-control" }) </th>
                                                <th> @Html.TextBox(@key + "_school", "", new { @class = "form-control" }) </th>
                                                <th> @Html.TextBox(@key + "_board", "", new { @class = "form-control" }) </th>
                                                <th> @Html.TextBox(@key + "_year", "", new { @class = "form-control" }) </th>
                                                <th> @Html.TextBox(@key + "_f_marks", "", new { @class = "form-control f_marks", mkey = key }) </th>
                                                <th> @Html.TextBox(@key + "_marks_obtain", "", new { @class = "form-control f_marks", mkey = key }) </th>
                                                <th> @Html.TextBox(@key + "_marks", "", new { @class = "form-control", mkey = key }) </th>
                                                <th> @Html.DropDownList(@key + "_division", "DISTINCTION,FIRST,SECOND,THIRD,NA", "Select", new { @class = "form-select" }) </th>
                                            </tr> } }

                                    </tbody>

                                </table>
                            </div>

                        </div>
                        <script>
                            $(function () {
                                mevent();
                            })
                            function mevent() {
                                $(".f_marks").on("input", function () {
                                    var key = $(this).attr("mkey");

                                    var fm = parseFloat($(`#${key}_f_marks`).val());
                                    console.log(fm);
                                    // Checking if 'fm' is not a number or is NaN, and setting it to 1 if true
                                    if (isNaN(fm) || !isFinite(fm)) {
                                        fm = 1;
                                    }

                                    // Extracting and converting the value of an input field with the ID `${key}_marks_obtain` to a floating-point number
                                    var mo = parseFloat($(`#${key}_marks_obtain`).val());

                                    // Checking if 'mo' is not a number or is NaN, and setting it to 0 if true
                                    if (isNaN(mo) || !isFinite(mo)) {
                                        mo = 0;
                                    }

                                    // Calculating the percentage only if 'fm' is not zero to avoid division by zero
                                    var p = fm !== 0 ? (mo * 100) / fm : 0;

                                    // Updating the value of an input field with the ID `${key}_marks`
                                    $(`#${key}_marks`).val(p.toFixed(2));
                                })
                            }

                        </script>


                        <h2 class="form-ttleS">Experience Details</h2>
                        <div class="row">
                            <div class="col-12">

                                <table class="table-bordered" id="tbl_exp" style="width: 100%;">
                                    <thead>
                                        <tr>
                                            <th style="width: 55px;">SL No</th>
                                            <th style="min-width: 300px;">Name of the Organization</th>
                                            <th>Designation</th>
                                            <th>Employment Duration</th>
                                            <th>Drawn Salary (Gross)</th>
                                            <th>Reason For Leaving</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @{ for (var a = 1; a < 5; a++)
                                                        {
                                            <tr>
                                                <th style="text-align:center">@a</th>
                                                <td> @Html.TextBox("org_name_" + @a, "", new { @class = "form-control" }) </td>
                                                <td> @Html.TextBox("org_designation_" + @a, "", new { @class = "form-control" }) </td>
                                                <td> @Html.TextBox("org_duration_" + @a, "", new { @class = "form-control" }) </td>
                                                <td> @Html.TextBox("org_salary_" + @a, "", new { @class = "form-control" }) </td>
                                                <td> @Html.TextBox("org_leaving_" + @a, "", new { @class = "form-control" }) </td>
                                            </tr> } }

                                    </tbody>

                                </table>
                            </div>

                        </div>

                    </div>


                    

