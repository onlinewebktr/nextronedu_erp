                            @Html.LabelEditor("Proficiency_In_Computer", "ddl", "Proficiency In Computer", em.Proficiency_In_Computer, isRequired: true, divCssClass: "col-md-6", ddl_comma_seperated: "NA,NO,YES")
                        </div>



