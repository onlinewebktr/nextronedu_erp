                    <div class="p-4 border rounded" style="padding: 0px 0px 20px 0px !important; float: left; width: 100%;" id="Page_Organization_info" visible="false">
                        <h2 class="form-ttleS">Office Use Only </h2>
                        <div class="g-3 needs-validation">
                            <div class="row">

                                @Html.LabelEditor("Punch_card", "text", "Punch Card No", value: emp.Punch_Card_no, divCssClass: "col-md-3")
                                @Html.LabelEditor("office_email", "text", "Official Email Id", value: emp.Official_email_id, divCssClass: "col-md-3")
                                @Html.LabelEditor("PAN", "text", "PAN", value: emp.Pan, divCssClass: "col-md-3")
                                @Html.LabelEditor("AadharNo", "text", "Aadhar No", value: emp.AadharNo, divCssClass: "col-md-3")

                                <h2 class="form-ttleS">Bank Account Details </h2>
                                @Html.LabelEditor("Bank_Name", "text", "Bank Name", emp.Bank_Name, divCssClass: "col-md-6")
                                @Html.LabelEditor("Branch", "text", "Branch", emp.Branch, divCssClass: "col-md-6")
                                @Html.LabelEditor("Account_No", "text", "Account No.", emp.Account_no, divCssClass: "col-md-4")
