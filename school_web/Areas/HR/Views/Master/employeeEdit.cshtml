                                @Html.LabelEditor("Salutation", "ddl", "Salutation", em.Salutation, true, editorHtmlAttributes: new { @readonly = "true" }, divCssClass: "col-md-3")

                                @Html.LabelEditor("First_Name", "text", "First Name", em.First_Name, true, divCssClass: "col-md-3")
                                @Html.LabelEditor("Middle_Name", "text", "Middle Name", em.Middle_Name, divCssClass: "col-md-3")

                                @Html.LabelEditor("Last_Name", "text", "Last Name", em.Last_Name, divCssClass: "col-md-3")
                                @Html.LabelEditor("Emailid", "text", "Email", emp.Email, isRequired: true, divCssClass: "col-md-3")
                                @Html.LabelEditor("Date_birthday", "date", "Date Of Birth", My.isValidDate(emp.Date_of_birth), isRequired: true, divCssClass: "col-md-3")
                                @Html.LabelEditor("Gender", "ddl", "Gender", emp.Gender, isRequired: true, divCssClass: "col-md-3", ddl_comma_seperated: "MALE,FEMALE, THIRD GENDER")
                                @Html.LabelEditor("Place_Of_Birth", "text", "Place Of Birth", em.Place_Of_Birth,   divCssClass: "col-md-3")
                                @Html.LabelEditor("Birth_State", "text", "Birth State", em.Birth_State,   divCssClass: "col-md-3")
                                @Html.LabelEditor("Religion", "ddl", "Religion", emp.Religion, isRequired: true, divCssClass: "col-md-3", ddl_comma_seperated: "HINDU,BUDDHIST,SIKH,CHRISTIAN,JAINISM,MUSLIM,OTHERS")
                                @Html.LabelEditor("Nationality", "text", "Nationality", em.Nationality, isRequired: true, divCssClass: "col-md-3")
                                @Html.LabelEditor("Marital_Status", "ddl", "Marital Status", emp.Marital_Status, isRequired: true, divCssClass: "col-md-3", ddl_comma_seperated: " MARRIED,UNMARRIED, DIVORCED,CHRISTIAN,WIDOWED")

                                @Html.LabelEditor("passport_photo", "file", "Passport Size Photo", em.passport_photo, isRequired: true, divCssClass: "col-md-6",area:"hr")
                                @Html.LabelEditor("Signature", "file", "Signature", em.Signature, isRequired: true, divCssClass: "col-md-6",area:"hr")
