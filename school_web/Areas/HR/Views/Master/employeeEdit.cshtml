
@{
    //Layout = null;
    ViewBag.ShowPageOnly = true;
    Employee_Apply em = ViewBag.emp as Employee_Apply;
    HR_Employee_Master emp = ViewBag.em as HR_Employee_Master;
    var isreadonly = "readonly";
    if (My.GlobalData("CalculateByGross") == "1")
    {
        isreadonly = "";
    }
}
<link href="~/Payroll/css/steps.css" rel="stylesheet" />
<style>
    .form-ttleS {
        margin: 0px 0px 0px 0px;
        padding: 8px 10px 5px 10px;
        width: 100%;
        float: left;
        font-size: 18px;
        color: #0296bd;
        border-bottom: 1px solid #ddd;
    }

    input[type=checkbox], input[type=radio] {
        border: 1px solid #b5b5b5;
        border-radius: 2px;
        cursor: pointer;
        height: 20px;
        margin: 0 4px 0 0;
        transition: border-color .2s linear,background-color .2s linear,box-shadow .2s linear;
        vertical-align: text-bottom;
        width: 20px;
    }

    .form-label {
        font-weight: 500;
        margin-bottom: 2px !important;
        margin-top: 2px !important;
    }

    th {
        font-weight: 500;
    }

    .form-control[readonly] {
        background-color: #fbfbfb;
    }

    .form-control:disabled {
        background-color: #e9ecef;
    }

    .online_frm-grp-h {
        height: auto;
        width: 100%;
        margin: 11px 0px 5px 0px;
        padding: 0px 0px 0px 0px;
        float: left;
        color: #000;
        font-weight: bold;
        font-size: 15px;
        line-height: 20px;
        text-align: left;
        font-family: 'IBM Plex Sans', sans-serif;
    }

    .form_control {
        border-color: rgb(18 18 19);
        width: 100%;
        margin: 0px 0px 0px 0px;
        padding: 3px 15px 3px 9px;
        float: left;
        border: 1px solid rgb(18 18 19);
        font-size: 14px;
        color: #000;
        height: 34px;
        text-align: left;
        border-radius: 4px;
        -webkit-box-shadow: inset 0 1px 1px rgb(0 0 0 / 8%);
        box-shadow: inset 0 1px 1px rgb(0 0 0 / 8%);
        -webkit-transition: border-color ease-in-out .15s,-webkit-box-shadow ease-in-out .15s;
        -o-transition: border-color ease-in-out .15s,box-shadow ease-in-out .15s;
        transition: border-color ease-in-out .15s,box-shadow ease-in-out .15s;
        font-family: 'IBM Plex Sans', sans-serif;
    }

    .border {
        border: 1px solid #ffffff !important;
    }

    .card-body {
        flex: 1 1 auto;
        padding: 0rem 1rem 1rem 1rem;
    }

    tfoot, th, thead {
        border-color: inherit;
        border-style: solid;
        border-width: 0;
        vertical-align: middle;
        background: #1cfdae !important;
    }
</style>
<script>
    history.pushState(null, null, window.location.href);
    history.back();
    window.onpopstate = () => history.forward();
</script>
<div class="page-breadcrumb d-flex align-items-center mb-2 eeewe">
    <div class="ps-3 d-none d-sm-flex">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 p-0">
                <li class="breadcrumb-item">
                    <a href="javascript:;"><i class="bx bx-home-alt"></i></a>
                </li>
                <li class="breadcrumb-item active" aria-current="page">@ViewBag.Title</li>
            </ol>
        </nav>
    </div>
</div>
<div class="row">
    <div class="col-xl-12">
        <form id="myForm">
            <input type="hidden" id="applyId" name="applyId" value="@em.Apply_id" />
            <input type="hidden" id="employee_id" name="employee_id" value="@emp.Employee_id" />
            <div class="card">
                <div class="card-body">

                    <div class="stepper-wrapper" id="stepper-div">
                        <div class="stepper-item active" data-id="page_personal_info">
                            <div class="step-counter">1</div>
                            <div class="step-name">Personal Information</div>
                        </div>

                        <div class="stepper-item" onclick="gotoPage(1)" data-id="page_communication_address_info">
                            <div class="step-counter">2</div>
                            <div class="step-name">Communication Address</div>
                        </div>

                        <div class="stepper-item" onclick="gotoPage(2)" data-id="page_family_info">
                            <div class="step-counter">3</div>
                            <div class="step-name">Family Information</div>
                        </div>
                        <div class="stepper-item" onclick="gotoPage(3)" data-id="Page_Academic_Maped">
                            <div class="step-counter">4</div>
                            <div class="step-name">Experience & Academic Qualification</div>
                        </div>
                        
                        <div class="stepper-item" onclick="gotoPage(4)" data-id="Page_Proficiency_Languagesn">
                            <div class="step-counter">5</div>
                            <div class="step-name">Proficiency in Languages</div>
                        </div>
                        <div class="stepper-item" onclick="gotoPage(5)" data-id="Page_Organization_info">
                            <div class="step-counter">6</div>
                            <div class="step-name">Office Use Only</div>
                        </div>
                        <div class="stepper-item" onclick="gotoPage(6)" data-id="Page_docoment">
                            <div class="step-counter">7</div>
                            <div class="step-name">Documents Upload</div>
                        </div>
                        <div class="stepper-item" onclick="gotoPage(7)" data-id="Page_Salary">
                            <div class="step-counter">8</div>
                            <div class="step-name">Salary Structure</div>
                        </div>
                    </div>

                    <div class="p-4 border rounded" style="padding: 0px 0px 20px 0px !important; float: left; width: 100%;" id="page_personal_info" visible="true">

