@{ Firm_Details firm = ViewBag.firm as Firm_Details;
    if (firm == null)
    {
        firm = Session["Firm_Details"] as Firm_Details;
    }
    if (firm == null)
    {
        Session["Firm_Details"] = firm = My.getFirmDetails();
    }
    ViewBag.firm_name = firm.firm_name;
    ViewBag.logo = firm.logo;
    if (User.Identity.IsAuthenticated)
    {
        My.getUserInfo(ViewBag, Session, User.Identity.Name);
    }
    if (ViewBag.logo == null)
    {
        ViewBag.logo = "../../Content/Images/logo.png'";
    } }
