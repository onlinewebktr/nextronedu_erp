                    var display = "display:none";
                    if (d.messagecount>0) {
                        display = "";
                    }
                    var liitem = `
                    <li class="gp_${a + 1}">
                        <div onclick="startchat('${d.user_id}','1','top')" class="button-30">
                            <div class="top-menu-ul-a-ico">
                                <span class="material-icons">groups</span>
                            </div>
                            <div class="top-menu-ul-a-name">${d.username}</div>
