    <script>
        let currentIndex = -1; // To keep track of the current search index
        let messages = []; // To store the messages for searching

        // Function to search messages
        function searchMessages() {
            const query = document.getElementById('searchInThisChat').value.toLowerCase();
            messages = Array.from(document.querySelectorAll('.tyn-reply-text'));
            const matchedMessages = messages.filter(message =>
                message.textContent.toLowerCase().includes(query)
            );

            // Reset current index if no matches found
            if (matchedMessages.length === 0) {
                currentIndex = -1;
                messages.forEach(message => message.style.backgroundColor = ''); // Clear highlights
                return;
            }

            // Highlight matched messages
            messages.forEach(message => {
                if (message.textContent.toLowerCase().includes(query)) {
                    message.style.backgroundColor = '#2fe154'; // Highlight color
                } else {
                    message.style.backgroundColor = ''; // Clear highlight
                }
            });
        }

        // Function to search upwards
        function searchUp() {
            const query = document.getElementById('searchInThisChat').value.toLowerCase();
            const matchedMessages = messages.filter(message =>
                message.textContent.toLowerCase().includes(query)
            );

            if (matchedMessages.length === 0) return; // No matches

            // Move to the previous match
            currentIndex = (currentIndex <= 0) ? matchedMessages.length - 1 : currentIndex - 1;

            // Scroll to the matched message
            matchedMessages[currentIndex].scrollIntoView({ behavior: 'smooth', block: 'center' });
        }

        // Function to search downwards
        function searchDown() {
            const query = document.getElementById('searchInThisChat').value.toLowerCase();
            const matchedMessages = messages.filter(message =>
                message.textContent.toLowerCase().includes(query)
            );

            if (matchedMessages.length === 0) return; // No matches

            // Move to the next match
            currentIndex = (currentIndex >= matchedMessages.length - 1) ? 0 : currentIndex + 1;

            // Scroll to the matched message
            matchedMessages[currentIndex].scrollIntoView({ behavior: 'smooth', block: 'center' });
        }

        // Event listeners for search input
        document.getElementById('searchInThisChat').addEventListener('input', searchMessages);
    </script>

