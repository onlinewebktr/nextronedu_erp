                            <span class="topupergroupid" id="gpid_${d.user_id}" style="display: none;">${d.user_id}</span>
                        </div>

                   <ul class="dropdown1" >
                    <li onclick="Add_Member('${d.user_id}')"><span class="material-icons">person_add</span>Add Member</li>
                    <li onclick="Remove_Member('${d.user_id}')"><span class="material-icons">person_remove</span>Remove Member</li>
                    <li onclick="editgroup('${d.user_id}')"><span class="material-icons">manage_accounts</span>Edit Group Name</li>
                </ul>
                    </li>`;

                    // Append the new list item to the <ul>
                    ul.append($(liitem));
                }
            });
            var creategroup;
            if ('@superadmin' == "Admin") {

                creategroup   = `
                    <li class="gp_7"  style="display: inline-block;" >
                        <div onclick="Createnewgroup()" class="button-30">
                            <div class="top-menu-ul-a-ico">
                                <span class="material-icons">add</span>
                            </div>
                            <div class="top-menu-ul-a-name">Create Group </div>

                        </div>
                    </li>`;
            }
            else {
                  creategroup = `
                    <li class="gp_7" style="display: none;" >
                        <div onclick="Createnewgroup()" class="button-30">
                            <div class="top-menu-ul-a-ico">
                                <span class="material-icons">add</span>
                            </div>
                            <div class="top-menu-ul-a-name">Create Group </div>

                        </div>
                    </li>`;
            }

            ul.append($(creategroup));
        } else {
            // Handle error
            alertError(resp.message);
        }
    });
}
