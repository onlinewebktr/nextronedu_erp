                <!-- Modal content-->
                <div class="modal-content menusidec" style="background-color: #f9f9f9;">
                    <div class="modal-header" style="padding: 0px;">
                        <a class="nav-link" href="#!" role="button" aria-expanded="false" style="color: #4fa700;">
                            <i class='bx bxs-calendar' title="Update Info"></i>Session :
                                   
                        </a>
                        <button type="button" class="mdl-close-btn" data-dismiss="modal" style="background: rgb(255 255 255 / 0%); border: 0px; padding: 1px 0px 1px 0px; margin: 0px 5px 0px 0px; color: #000; border: 1px solid #e3e3e3; line-height: 0px;">
                            <span class="material-icons" style="font-size: 22px;">close</span></button>
                    </div>
                    <div class="modal-body md-bdy" style="padding: 0px;">
                        <div class="p-side-menu">
                            <ul class="p-side-menu-ul">
                                <asp:Repeater ID="rp_side_menu" runat="server">
                                    <ItemTemplate>
                                        <li class="<%#Eval("ForTopMenu") %>">
                                            <a href="<%#Eval("Page_link") %>">
                                                <div class="p-side-menu-a-ico">
                                                    <span class="material-icons"><%#Eval("Group_icon") %></span>
                                                </div>
                                                <div class="p-side-menu-a-name"><%#Eval("Group_name") %></div>
                                            </a>
                                        </li>
                                    </ItemTemplate>
                                </asp:Repeater>
                                <li>
                                    <a href="Help.aspx">
                                        <div class="p-side-menu-a-ico">
                                            <span class="material-icons">quiz</span>
                                        </div>
                                        <div class="p-side-menu-a-name">Help</div>
                                    </a>
